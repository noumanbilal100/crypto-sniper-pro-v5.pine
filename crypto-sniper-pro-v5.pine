// ════════════════════════════════════════════════════════════════════
// CRYPTO SNIPER PRO v5.0  —  Master Strategy (Pine v6)
// ════════════════════════════════════════════════════════════════════
// 20 INTEGRATED FEATURES · ADAPTIVE MTF · KITCHEN SINK
//
// FOUNDATION (4 + 1)
//   1. Adaptive MTF trend stack
//   2. External market structure (HH/HL/LH/LL, BOS, CHoCH)
//   3. Smart money zones (OB, FVG, filtered sweeps)
//   4. BTC correlation gate
//   +. HTF S/R confluence (auto-detected pivots)
//
// CONFLUENCE GATES (6 + 4)
//   5. RSI + divergence
//   6. MACD momentum shift
//   7. Volume spike validation
//   8. Pattern qualifier
//   9. Session timing
//  10. Volatility regime (ATR + ADX)
//   +. CVD proxy divergence
//   +. Funding rate gate (manual)
//   +. Open Interest divergence
//   +. News/event blackout (manual)
//
// RISK & EXECUTION (5 + 1)
//  11. Adaptive ATR sizing
//  12. Partial profit at 1R + BE
//  13. Multi-target TP (TP1/TP2/Trail)
//  14. Daily loss circuit breaker (-3%)
//  15. Win/loss streak adjustment
//  16. Discipline rules
//
// OUTPUT (3 + 1)
//  17. Full dashboard
//  18. Backtest metrics (incl. Sharpe approximation)
//  19. Webhook JSON alerts + plain text
//  20. Visual signals + zone boxes
//
// PRESETS: Strict · Balanced · Aggressive · Custom
// ════════════════════════════════════════════════════════════════════

//@version=6
strategy("Crypto Sniper Pro v5",
     shorttitle              = "CSP v5",
     overlay                 = true,
     initial_capital         = 10000,
     default_qty_type        = strategy.percent_of_equity,
     default_qty_value       = 10,
     commission_type         = strategy.commission.percent,
     commission_value        = 0.05,
     slippage                = 2,
     pyramiding              = 1,
     calc_on_every_tick      = false,
     calc_on_order_fills     = false,
     process_orders_on_close = true,
     max_boxes_count         = 150,
     max_lines_count         = 150,
     max_labels_count        = 150,
     max_bars_back           = 500)

// ════════════════════════════════════════════════════════════════════
// 🎚 PRESET SELECTOR
// ════════════════════════════════════════════════════════════════════
g_preset = "🎚 Preset"
i_preset = input.string("Balanced", "Strategy Preset",
     options=["Strict (sniper)", "Balanced", "Aggressive", "Scalping", "Aggressive Scalping", "Custom"], group=g_preset,
     tooltip="Strict = 1-3 trades/week max accuracy · Balanced = 3-8/week · Aggressive = 10-20/week · Scalping = 5-15 trades/DAY tight stops · Aggressive Scalping = 15-40/day max frequency · Custom = use your own settings")

// Preset values - optimized per trading style
preset_minConfirm = i_preset == "Strict (sniper)" ? 5 : i_preset == "Balanced" ? 3 : i_preset == "Aggressive" ? 2 : i_preset == "Scalping" ? 3 : i_preset == "Aggressive Scalping" ? 2 : 3
preset_minConf    = i_preset == "Strict (sniper)" ? 80 : i_preset == "Balanced" ? 65 : i_preset == "Aggressive" ? 50 : i_preset == "Scalping" ? 60 : i_preset == "Aggressive Scalping" ? 45 : 65
preset_cooldown   = i_preset == "Strict (sniper)" ? 20 : i_preset == "Balanced" ? 10 : i_preset == "Aggressive" ? 5 : i_preset == "Scalping" ? 3 : i_preset == "Aggressive Scalping" ? 1 : 10
preset_minRR      = i_preset == "Strict (sniper)" ? 2.5 : i_preset == "Balanced" ? 2.0 : i_preset == "Aggressive" ? 1.5 : i_preset == "Scalping" ? 1.5 : i_preset == "Aggressive Scalping" ? 1.2 : 2.0
preset_maxDaily   = i_preset == "Strict (sniper)" ? 2 : i_preset == "Balanced" ? 3 : i_preset == "Aggressive" ? 6 : i_preset == "Scalping" ? 15 : i_preset == "Aggressive Scalping" ? 40 : 3

// Scalping-specific adjustments
isScalping = i_preset == "Scalping" or i_preset == "Aggressive Scalping"
isAggScalp = i_preset == "Aggressive Scalping"

// ════════════════════════════════════════════════════════════════════
// INPUTS
// ════════════════════════════════════════════════════════════════════

// — Master Switches —
g_master = "🔌 Master Switches"
i_useMTF       = input.bool(true, "MTF Trend Stack", group=g_master)
i_useStruct    = input.bool(true, "External Structure", group=g_master)
i_useSMC       = input.bool(true, "Smart Money Zones (OB/FVG)", group=g_master)
i_useBTC       = input.bool(true, "BTC Correlation Gate", group=g_master)
i_useHTFsr     = input.bool(true, "HTF S/R Confluence", group=g_master)
i_useRSI       = input.bool(true, "RSI Confirmation", group=g_master)
i_useMACD      = input.bool(true, "MACD Confirmation", group=g_master)
i_useVol       = input.bool(true, "Volume Validation", group=g_master)
i_useSession   = input.bool(true, "Session Filter", group=g_master)
i_useVolReg    = input.bool(true, "Volatility Regime", group=g_master)
i_useCVD       = input.bool(true, "CVD Divergence", group=g_master)
i_useFunding   = input.bool(false, "Funding Rate Gate", group=g_master)
i_useOI        = input.bool(false, "Open Interest Divergence", group=g_master)
i_useNewsBlock = input.bool(true,  "News/Event Blackout", group=g_master)
i_useSentiment = input.bool(true,  "🌡 Crypto Sentiment Engine", group=g_master)
i_usePartialTP = input.bool(true, "Partial TP + BE", group=g_master)
i_useMultiTP   = input.bool(true, "Multi-Target TP", group=g_master)
i_useDailyDD   = input.bool(true, "Daily Loss Circuit Breaker", group=g_master)
i_useStreakAdj = input.bool(true, "Win/Loss Streak Sizing", group=g_master)

// — Custom Override (only used if preset = Custom) —
g_custom = "🛠 Custom Overrides (Custom preset only)"
i_customMinConf  = input.int(3, "Min Confirmations (custom)", group=g_custom, minval=1, maxval=10)
i_customConfPct  = input.int(65, "Min Confidence % (custom)", group=g_custom, minval=40, maxval=95)
i_customCooldown = input.int(10, "Cooldown bars (custom)", group=g_custom, minval=1, maxval=100)
i_customRR       = input.float(2.0, "Min R:R (custom)", group=g_custom, step=0.1, minval=1.0)
i_customMaxDay   = input.int(3, "Max trades/day (custom)", group=g_custom, minval=1, maxval=20)

// Resolved active values
minConfirm = i_preset == "Custom" ? i_customMinConf  : preset_minConfirm
minConf    = i_preset == "Custom" ? i_customConfPct  : preset_minConf
cooldown   = i_preset == "Custom" ? i_customCooldown : preset_cooldown
minRR      = i_preset == "Custom" ? i_customRR       : preset_minRR
maxPerDay  = i_preset == "Custom" ? i_customMaxDay   : preset_maxDaily

// — Adaptive MTF —
g_mtf = "🔭 Adaptive MTF Stack"
i_mtfMode = input.string("Auto-adaptive", "MTF Mode", options=["Auto-adaptive","Manual"], group=g_mtf,
     tooltip="Auto: scales higher TFs from your chart TF. Manual: you pick all 3.")
i_mtf1 = input.timeframe("60",  "Manual TF 1", group=g_mtf)
i_mtf2 = input.timeframe("240", "Manual TF 2", group=g_mtf)
i_mtf3 = input.timeframe("D",   "Manual TF 3", group=g_mtf)

// — Structure —
g_struct = "🏗 Structure / SMC"
i_pivotLen   = input.int(15, "External Pivot Length", group=g_struct, minval=5, maxval=50)
i_bosMinATR  = input.float(0.5, "Min BOS Distance (× ATR)", group=g_struct, step=0.1)
i_obImpulse  = input.float(1.5, "OB Impulse Threshold (× ATR)", group=g_struct, step=0.1)
i_obMaxBars  = input.int(50, "OB Max Age (bars)", group=g_struct)
i_fvgMinATR  = input.float(0.4, "Min FVG Size (× ATR)", group=g_struct, step=0.1)

// — Liquidity —
g_liq = "💧 Liquidity Filter"
i_liqNearATR   = input.float(1.0, "Sweep within (× ATR) of pivot", group=g_liq, step=0.1)
i_requireTrend = input.bool(true, "Require prior trend move", group=g_liq)

// — HTF S/R —
g_htfsr = "🏛 HTF S/R Confluence"
i_htfsrTF        = input.timeframe("D", "HTF S/R Timeframe", group=g_htfsr)
i_htfsrLookback  = input.int(180, "HTF Lookback bars", group=g_htfsr, minval=30)
i_htfsrPivotLen  = input.int(5, "HTF Pivot Length", group=g_htfsr, minval=3)
i_htfsrProxATR   = input.float(1.5, "Proximity to HTF level (× ATR)", group=g_htfsr, step=0.1)

// — RSI —
g_rsi = "📊 RSI"
i_rsiLen    = input.int(14, "Length", group=g_rsi)
i_rsiOB     = input.int(70, "Overbought", group=g_rsi)
i_rsiOS     = input.int(30, "Oversold", group=g_rsi)
i_rsiDivLen = input.int(5, "Divergence Lookback", group=g_rsi, minval=3, maxval=20)

// — MACD —
g_macd = "📊 MACD"
i_macdFast = input.int(12, "Fast", group=g_macd)
i_macdSlow = input.int(26, "Slow", group=g_macd)
i_macdSig  = input.int(9,  "Signal", group=g_macd)

// — Volume / CVD —
g_vol = "📊 Volume + CVD"
i_volLen     = input.int(20,  "Volume MA Length", group=g_vol)
i_volSpike   = input.float(1.5, "Volume Spike Threshold (× avg)", group=g_vol, step=0.1)
i_cvdLen     = input.int(14,  "CVD smoothing", group=g_vol)
i_cvdDivLen  = input.int(10,  "CVD divergence lookback", group=g_vol)

// — BTC —
g_btc = "₿ BTC Correlation"
i_btcSymbol  = input.symbol("BINANCE:BTCUSDT", "BTC Reference", group=g_btc)
i_btcTrendTF = input.timeframe("60", "BTC Trend TF", group=g_btc)

// — Funding & OI (manual) —
g_funding = "💰 Funding & OI (Manual)"
i_fundingPct  = input.float(0.0, "Current Funding Rate %", group=g_funding, step=0.001,
     tooltip="Get from exchange. >0.05 = crowd overlong (bearish bias). <-0.03 = crowd overshort (bullish bias)")
i_oiSymbol    = input.symbol("BINANCE:BTCUSDT", "OI Symbol Reference (or paste OI symbol if available)", group=g_funding)
i_oiUseProxy  = input.bool(true, "Use volume×price as OI proxy (if no OI feed)", group=g_funding)

// — Crypto Sentiment Engine —
g_sent = "🌡 Crypto Sentiment (free, multi-source)"
i_btcDomSymbol   = input.symbol("CRYPTOCAP:BTC.D",   "BTC Dominance Symbol",   group=g_sent)
i_usdtDomSymbol  = input.symbol("CRYPTOCAP:USDT.D",  "Stablecoin Dominance",   group=g_sent)
i_totalMcSymbol  = input.symbol("CRYPTOCAP:TOTAL",   "Total Crypto Market Cap",group=g_sent)
i_total3Symbol   = input.symbol("CRYPTOCAP:TOTAL3",  "Alts Market Cap (TOTAL3)",group=g_sent)
i_sentTF         = input.timeframe("D", "Sentiment Timeframe", group=g_sent,
     tooltip="Use D for swing, 4H for intraday")
i_sentExtreme    = input.int(70, "Extreme threshold for sentiment score", group=g_sent, minval=50, maxval=90,
     tooltip="Sentiment > this = extreme greed (bearish bias). Sentiment < (100-this) = extreme fear (bullish bias)")

// — Session —
g_sess = "🕐 Session Filter"
i_sessLondon = input.session("0700-1600", "London (UTC)", group=g_sess)
i_sessNY     = input.session("1300-2200", "NY (UTC)", group=g_sess)
i_sessTZ     = input.string("UTC", "Session Timezone", group=g_sess)
i_skipWeekend= input.bool(false, "Skip weekends (spot trading)", group=g_sess)

// — Volatility Regime —
g_volreg = "💨 Volatility Regime"
i_atrMinPct = input.float(0.3, "Min ATR % of price", group=g_volreg, step=0.05)
i_adxLen    = input.int(14, "ADX Length", group=g_volreg)
i_adxMin    = input.float(20, "Min ADX", group=g_volreg, step=1)

// — News & Event Blackout (Smart auto + manual) —
g_news = "📰 News / Event Blackout"
i_newsAuto       = input.bool(true,  "🤖 Auto-detect recurring high-impact events", group=g_news,
     tooltip="Automatically blocks trading around: FOMC Wednesdays 18:00 UTC · CPI 2nd Tuesday 12:30 UTC · NFP 1st Friday 12:30 UTC · Daily 00:00 UTC (Asia open volatility)")
i_newsAutoBefore = input.int(60, "Block N minutes BEFORE event", group=g_news, minval=0, maxval=240)
i_newsAutoAfter  = input.int(30, "Block N minutes AFTER event",  group=g_news, minval=0, maxval=240)
i_newsBlockFOMC  = input.bool(true,  "Block FOMC (Wed 18:00 UTC)",   group=g_news)
i_newsBlockCPI   = input.bool(true,  "Block CPI (2nd Tue 12:30 UTC)", group=g_news)
i_newsBlockNFP   = input.bool(true,  "Block NFP (1st Fri 12:30 UTC)", group=g_news)
i_newsBlockMidnight = input.bool(false, "Block Daily Reset (00:00 UTC ±15m)", group=g_news)
i_newsBlockWeekend  = input.bool(false, "Block Weekend Open (Sun 22:00 UTC ±2h)", group=g_news)
i_news1Start = input.time(timestamp("2025-01-01 00:00"), "Manual Event 1 Start", group=g_news)
i_news1End   = input.time(timestamp("2025-01-01 00:00"), "Manual Event 1 End",   group=g_news)
i_news2Start = input.time(timestamp("2025-01-01 00:00"), "Manual Event 2 Start", group=g_news)
i_news2End   = input.time(timestamp("2025-01-01 00:00"), "Manual Event 2 End",   group=g_news)
i_news3Start = input.time(timestamp("2025-01-01 00:00"), "Manual Event 3 Start", group=g_news)
i_news3End   = input.time(timestamp("2025-01-01 00:00"), "Manual Event 3 End",   group=g_news)

// — Risk —
g_risk = "🛡 Risk Management"
i_riskPct      = input.float(1.0, "Risk per Trade (% equity)", group=g_risk, step=0.1, minval=0.1, maxval=3.0)
i_slBufATR     = input.float(0.3, "SL Buffer (× ATR)", group=g_risk, step=0.1)
i_adaptiveATR  = input.bool(true, "Adaptive ATR (scale SL with vol)", group=g_risk)
i_atrLowMult   = input.float(1.5, "SL × ATR in LOW vol", group=g_risk, step=0.1)
i_atrHighMult  = input.float(3.0, "SL × ATR in HIGH vol", group=g_risk, step=0.1)

// — Multi-target TP —
g_tp = "🎯 Multi-Target TP"
i_tp1R     = input.float(1.5, "TP1 (× R)", group=g_tp, step=0.1)
i_tp1Pct   = input.float(40, "TP1 % of position", group=g_tp, step=5)
i_tp2R     = input.float(3.0, "TP2 (× R)", group=g_tp, step=0.1)
i_tp2Pct   = input.float(30, "TP2 % of position", group=g_tp, step=5)
i_trailATR = input.float(2.5, "Runner Trail (× ATR)", group=g_tp, step=0.1)

// — Daily DD —
g_dd = "🚨 Daily Drawdown"
i_maxDailyDD = input.float(3.0, "Max Daily Loss %", group=g_dd, step=0.5, minval=1, maxval=20)

// — Streak Adjustment —
g_streak = "🔄 Streak Sizing"
i_lossStreak       = input.int(2, "Loss streak → reduce size", group=g_streak, minval=2, maxval=10)
i_lossStreakReduce = input.float(50, "Size reduction % on loss streak", group=g_streak, step=5)
i_winStreak        = input.int(3, "Win streak → increase size", group=g_streak, minval=2, maxval=10)
i_winStreakAdd     = input.float(50, "Size increase % on win streak", group=g_streak, step=5)

// — Discipline —
g_disc = "🧠 Discipline"
i_allowLong  = input.bool(true,  "Allow LONG",  group=g_disc)
i_allowShort = input.bool(true,  "Allow SHORT", group=g_disc)

// — Backtest dates —
g_date = "📅 Backtest Range"
i_useDate   = input.bool(false, "Use Date Filter", group=g_date)
i_dateStart = input.time(timestamp("2024-01-01 00:00"), "Start", group=g_date)
i_dateEnd   = input.time(timestamp("2030-01-01 00:00"), "End",   group=g_date)

// — Visualization —
g_vis = "🎨 Visualization"
i_showEMA      = input.bool(true, "Show EMAs", group=g_vis)
i_showStruct   = input.bool(true, "Show External Structure", group=g_vis)
i_showOB       = input.bool(true, "Show Order Blocks", group=g_vis)
i_showFVG      = input.bool(true, "Show Fair Value Gaps", group=g_vis)
i_showHTFsr    = input.bool(true, "Show HTF S/R Lines", group=g_vis)
i_showWyckoff  = input.bool(true, "Show Wyckoff Phases (background tint)", group=g_vis)
i_showPhaseLbl = input.bool(true, "Show Phase Label (on chart)", group=g_vis)
i_showSignals  = input.bool(true, "Show Entry Signals", group=g_vis)
i_showSLTP     = input.bool(true, "Show SL/TP Lines", group=g_vis)
i_showDash     = input.bool(true, "Show Dashboard", group=g_vis)
i_dashPos      = input.string("Top Right", "Dashboard Position",
     options=["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right"], group=g_vis)

// Text & label size control
i_textSize     = input.string("Tiny", "📏 Text Size (Dashboard + Labels)",
     options=["Tiny","Small","Normal","Large","Huge"], group=g_vis,
     tooltip="DEFAULT IS TINY (mobile-friendly). Change to Large/Huge on desktop if you want bigger text.")
i_labelSize    = input.string("Small", "📏 On-chart Label Size",
     options=["Tiny","Small","Normal","Large","Huge"], group=g_vis,
     tooltip="Size of CHoCH, Phase, and Signal labels on the chart")

// Resolve size enums
sizeText  = i_textSize  == "Tiny" ? size.tiny : i_textSize  == "Small" ? size.small : i_textSize  == "Normal" ? size.normal : i_textSize  == "Large" ? size.large : size.huge
sizeLabel = i_labelSize == "Tiny" ? size.tiny : i_labelSize == "Small" ? size.small : i_labelSize == "Normal" ? size.normal : i_labelSize == "Large" ? size.large : size.huge
sizeHeader = i_textSize == "Tiny" ? size.small : i_textSize == "Small" ? size.normal : i_textSize == "Normal" ? size.large : size.huge

// — Alerts —
g_alert = "🔔 Alerts"
i_alertFormat = input.string("Plain Text", "Alert Format", options=["Plain Text","JSON (webhook)"], group=g_alert)

// ════════════════════════════════════════════════════════════════════
// 🔧 ADAPTIVE TF RESOLUTION
// ════════════════════════════════════════════════════════════════════
tfMins = timeframe.in_seconds(timeframe.period) / 60

// Auto-pick MTFs based on chart TF
mtf1_auto = tfMins <= 1   ? "5"   : tfMins <= 5   ? "15"  : tfMins <= 15  ? "60" : tfMins <= 60  ? "240" : tfMins <= 240 ? "D" : tfMins <= 1440 ? "W" : "W"
mtf2_auto = tfMins <= 1   ? "15"  : tfMins <= 5   ? "60"  : tfMins <= 15  ? "240": tfMins <= 60  ? "D"   : tfMins <= 240 ? "W" : tfMins <= 1440 ? "M" : "M"
mtf3_auto = tfMins <= 1   ? "60"  : tfMins <= 5   ? "240" : tfMins <= 15  ? "D"  : tfMins <= 60  ? "W"   : tfMins <= 240 ? "M" : tfMins <= 1440 ? "3M" : "12M"

mtf1 = i_mtfMode == "Auto-adaptive" ? mtf1_auto : i_mtf1
mtf2 = i_mtfMode == "Auto-adaptive" ? mtf2_auto : i_mtf2
mtf3 = i_mtfMode == "Auto-adaptive" ? mtf3_auto : i_mtf3

// ════════════════════════════════════════════════════════════════════
// CORE CALCULATIONS
// ════════════════════════════════════════════════════════════════════
atr      = ta.atr(14)
atrLong  = ta.atr(50)
atrRatio = atr / atrLong
isLowVol  = atrRatio < 0.8
isHighVol = atrRatio > 1.2

isBTCSymbol = str.contains(syminfo.ticker, "BTC")

// ── EMAs (LTF) ──────────────────────────────────────────────────────
ema20  = ta.ema(close, 20)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

emaBull  = ema20 > ema50 and ema50 > ema200
emaBear  = ema20 < ema50 and ema50 < ema200
emaSlope = ta.change(ema50, 5)

ltfTrendBull = emaBull and emaSlope > 0
ltfTrendBear = emaBear and emaSlope < 0

// Global trend label (used in dashboard + signal tooltips)
trendLabel = ltfTrendBull ? "STRONG BULL" : ltfTrendBear ? "STRONG BEAR" : emaBull ? "BULL" : emaBear ? "BEAR" : "MIXED"

// ── MTF Trend Stack ─────────────────────────────────────────────────
[mtf1_e20, mtf1_e50] = request.security(syminfo.tickerid, mtf1, [ta.ema(close,20), ta.ema(close,50)], lookahead=barmerge.lookahead_off)
[mtf2_e20, mtf2_e50] = request.security(syminfo.tickerid, mtf2, [ta.ema(close,20), ta.ema(close,50)], lookahead=barmerge.lookahead_off)
[mtf3_e20, mtf3_e50] = request.security(syminfo.tickerid, mtf3, [ta.ema(close,20), ta.ema(close,50)], lookahead=barmerge.lookahead_off)

mtf1Bias = mtf1_e20 > mtf1_e50 ? 1 : mtf1_e20 < mtf1_e50 ? -1 : 0
mtf2Bias = mtf2_e20 > mtf2_e50 ? 1 : mtf2_e20 < mtf2_e50 ? -1 : 0
mtf3Bias = mtf3_e20 > mtf3_e50 ? 1 : mtf3_e20 < mtf3_e50 ? -1 : 0

mtfBullScore = (mtf1Bias == 1 ? 1 : 0) + (mtf2Bias == 1 ? 1 : 0) + (mtf3Bias == 1 ? 1 : 0)
mtfBearScore = (mtf1Bias == -1 ? 1 : 0) + (mtf2Bias == -1 ? 1 : 0) + (mtf3Bias == -1 ? 1 : 0)

mtfFullBull = not i_useMTF or mtfBullScore == 3
mtfFullBear = not i_useMTF or mtfBearScore == 3

// ── External Structure ──────────────────────────────────────────────
extHigh = ta.pivothigh(high, i_pivotLen, i_pivotLen)
extLow  = ta.pivotlow(low,   i_pivotLen, i_pivotLen)

var float lastExtHigh = na
var float prevExtHigh = na
var int   lastExtHighBar = na
var float lastExtLow  = na
var float prevExtLow  = na
var int   lastExtLowBar  = na

if not na(extHigh)
    prevExtHigh    := lastExtHigh
    lastExtHigh    := extHigh
    lastExtHighBar := bar_index - i_pivotLen
if not na(extLow)
    prevExtLow    := lastExtLow
    lastExtLow    := extLow
    lastExtLowBar := bar_index - i_pivotLen

extBullStruct = not na(lastExtHigh) and not na(prevExtHigh) and not na(lastExtLow) and not na(prevExtLow) and lastExtHigh > prevExtHigh and lastExtLow > prevExtLow
extBearStruct = not na(lastExtHigh) and not na(prevExtHigh) and not na(lastExtLow) and not na(prevExtLow) and lastExtHigh < prevExtHigh and lastExtLow < prevExtLow

structOK_long_simple  = not i_useStruct or not extBearStruct
structOK_short_simple = not i_useStruct or not extBullStruct

structureBias = extBullStruct ? 1 : extBearStruct ? -1 : 0

bosBull = not na(lastExtHigh) and barstate.isconfirmed and close > lastExtHigh + atr * i_bosMinATR and close[1] <= lastExtHigh
bosBear = not na(lastExtLow)  and barstate.isconfirmed and close < lastExtLow  - atr * i_bosMinATR and close[1] >= lastExtLow

chochBull = extBearStruct and bosBull
chochBear = extBullStruct and bosBear

// ── Liquidity Sweeps ────────────────────────────────────────────────
priorMove    = math.abs(close - close[10])
hadTrendMove = priorMove > atr * 3

rawSweepHigh = not na(lastExtHigh) and high > lastExtHigh and close < lastExtHigh
rawSweepLow  = not na(lastExtLow)  and low  < lastExtLow  and close > lastExtLow

nearExtHigh = not na(lastExtHigh) and math.abs(high - lastExtHigh) <= atr * i_liqNearATR
nearExtLow  = not na(lastExtLow)  and math.abs(low  - lastExtLow)  <= atr * i_liqNearATR

trendOK   = not i_requireTrend or hadTrendMove
sweepHigh = rawSweepHigh and nearExtHigh and trendOK and barstate.isconfirmed
sweepLow  = rawSweepLow  and nearExtLow  and trendOK and barstate.isconfirmed

// ── Order Blocks ────────────────────────────────────────────────────
impulseUp   = close - open > atr * i_obImpulse and close > open
impulseDown = open - close > atr * i_obImpulse and close < open

var float bullOB_top = na
var float bullOB_bot = na
var int   bullOB_bar = na
var bool  bullOB_fresh = false
var float bearOB_top = na
var float bearOB_bot = na
var int   bearOB_bar = na
var bool  bearOB_fresh = false

if impulseUp and close[1] < open[1]
    bullOB_top := open[1]
    bullOB_bot := close[1]
    bullOB_bar := bar_index - 1
    bullOB_fresh := true

if impulseDown and close[1] > open[1]
    bearOB_top := close[1]
    bearOB_bot := open[1]
    bearOB_bar := bar_index - 1
    bearOB_fresh := true

if bullOB_fresh and low <= bullOB_bot
    bullOB_fresh := false
if bearOB_fresh and high >= bearOB_top
    bearOB_fresh := false

bullOBValid = bullOB_fresh and not na(bullOB_bar) and (bar_index - bullOB_bar) <= i_obMaxBars
bearOBValid = bearOB_fresh and not na(bearOB_bar) and (bar_index - bearOB_bar) <= i_obMaxBars

inBullOB = bullOBValid and low <= bullOB_top and high >= bullOB_bot
inBearOB = bearOBValid and high >= bearOB_bot and low <= bearOB_top

// ── FVG ─────────────────────────────────────────────────────────────
bullFVG = low > high[2] and (low - high[2]) >= atr * i_fvgMinATR
bearFVG = high < low[2] and (low[2] - high) >= atr * i_fvgMinATR

var float bullFVG_top = na
var float bullFVG_bot = na
var bool  bullFVG_active = false
var int   bullFVG_bar = na
var float bearFVG_top = na
var float bearFVG_bot = na
var bool  bearFVG_active = false
var int   bearFVG_bar = na

if bullFVG
    bullFVG_top := low
    bullFVG_bot := high[2]
    bullFVG_bar := bar_index - 2
    bullFVG_active := true
if bearFVG
    bearFVG_top := low[2]
    bearFVG_bot := high
    bearFVG_bar := bar_index - 2
    bearFVG_active := true

if bullFVG_active and low <= bullFVG_bot
    bullFVG_active := false
if bearFVG_active and high >= bearFVG_top
    bearFVG_active := false

inBullFVG = bullFVG_active and low <= bullFVG_top and close >= bullFVG_bot
inBearFVG = bearFVG_active and high >= bearFVG_bot and close <= bearFVG_top

// ── HTF S/R Confluence ──────────────────────────────────────────────
htfHigh = request.security(syminfo.tickerid, i_htfsrTF, ta.pivothigh(high, i_htfsrPivotLen, i_htfsrPivotLen), lookahead=barmerge.lookahead_off)
htfLow  = request.security(syminfo.tickerid, i_htfsrTF, ta.pivotlow(low,   i_htfsrPivotLen, i_htfsrPivotLen), lookahead=barmerge.lookahead_off)

var float htfR1 = na
var float htfR2 = na
var float htfS1 = na
var float htfS2 = na

if not na(htfHigh)
    htfR2 := htfR1
    htfR1 := htfHigh
if not na(htfLow)
    htfS2 := htfS1
    htfS1 := htfLow

nearHTFsupport = (not na(htfS1) and math.abs(low - htfS1) <= atr * i_htfsrProxATR) or (not na(htfS2) and math.abs(low - htfS2) <= atr * i_htfsrProxATR)
nearHTFresist  = (not na(htfR1) and math.abs(high - htfR1) <= atr * i_htfsrProxATR) or (not na(htfR2) and math.abs(high - htfR2) <= atr * i_htfsrProxATR)

htfsrConfLong  = not i_useHTFsr or nearHTFsupport
htfsrConfShort = not i_useHTFsr or nearHTFresist

// ── RSI + Divergence ────────────────────────────────────────────────
rsi = ta.rsi(close, i_rsiLen)

rsiBullZone   = rsi > 45 and rsi < 70
rsiBearZone   = rsi < 55 and rsi > 30
rsiOversold   = rsi < i_rsiOS
rsiOverbought = rsi > i_rsiOB

priceLL = low  < ta.lowest(low,  i_rsiDivLen)[1]
rsiHL   = rsi  > ta.lowest(rsi,  i_rsiDivLen)[1]
bullDiv = priceLL and rsiHL and rsi < 40

priceHH = high > ta.highest(high, i_rsiDivLen)[1]
rsiLH   = rsi  < ta.highest(rsi,  i_rsiDivLen)[1]
bearDiv = priceHH and rsiLH and rsi > 60

rsiConfBull = not i_useRSI or rsiBullZone or rsiOversold or bullDiv
rsiConfBear = not i_useRSI or rsiBearZone or rsiOverbought or bearDiv

// ── MACD ────────────────────────────────────────────────────────────
[macdLine, signalLine, histLine] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSig)
macdBullShift = ta.crossover(macdLine,  signalLine) or (macdLine > signalLine and histLine > histLine[1] and histLine[1] < 0)
macdBearShift = ta.crossunder(macdLine, signalLine) or (macdLine < signalLine and histLine < histLine[1] and histLine[1] > 0)
macdBullState = macdLine > signalLine and histLine > 0
macdBearState = macdLine < signalLine and histLine < 0

macdConfBull = not i_useMACD or macdBullShift or macdBullState
macdConfBear = not i_useMACD or macdBearShift or macdBearState

// ── Volume ──────────────────────────────────────────────────────────
volMA      = ta.sma(volume, i_volLen)
volSpike   = volume > volMA * i_volSpike
volConfirm = not i_useVol or (volSpike and barstate.isconfirmed)

// ── CVD Divergence ──────────────────────────────────────────────────
bullVol = close > open ? volume : 0.0
bearVol = close < open ? volume : 0.0
cvdDelta = ta.ema(bullVol - bearVol, i_cvdLen)

// CVD divergence
priceLowest  = ta.lowest(close, i_cvdDivLen)
priceHighest = ta.highest(close, i_cvdDivLen)
cvdLowest    = ta.lowest(cvdDelta, i_cvdDivLen)
cvdHighest   = ta.highest(cvdDelta, i_cvdDivLen)

cvdBullDiv = close <= priceLowest and cvdDelta > cvdLowest[1]
cvdBearDiv = close >= priceHighest and cvdDelta < cvdHighest[1]

cvdConfBull = not i_useCVD or cvdDelta > 0 or cvdBullDiv
cvdConfBear = not i_useCVD or cvdDelta < 0 or cvdBearDiv

// ── BTC Correlation ─────────────────────────────────────────────────
btcClose = request.security(i_btcSymbol, i_btcTrendTF, close,            lookahead=barmerge.lookahead_off)
btcE20   = request.security(i_btcSymbol, i_btcTrendTF, ta.ema(close,20), lookahead=barmerge.lookahead_off)
btcE50   = request.security(i_btcSymbol, i_btcTrendTF, ta.ema(close,50), lookahead=barmerge.lookahead_off)
btcBull  = btcE20 > btcE50 and btcClose > btcE20
btcBear  = btcE20 < btcE50 and btcClose < btcE20

btcOKLong  = isBTCSymbol or not i_useBTC or btcBull
btcOKShort = isBTCSymbol or not i_useBTC or btcBear

// ── 🌡 CRYPTO SENTIMENT ENGINE (4-source composite) ───────────────────
// Combines: BTC Dominance · USDT Dominance · TOTAL Market Cap · TOTAL3 (alts)
// Output: 0-100 score (0=extreme fear/bad for longs, 100=extreme greed/bad for shorts)
//         Plus per-pair bias adjustment based on whether trading BTC vs alt

// Pull HTF data (no repaint)
btcDom_close  = request.security(i_btcDomSymbol,  i_sentTF, close, lookahead=barmerge.lookahead_off)
btcDom_ema20  = request.security(i_btcDomSymbol,  i_sentTF, ta.ema(close,20), lookahead=barmerge.lookahead_off)
btcDom_ema50  = request.security(i_btcDomSymbol,  i_sentTF, ta.ema(close,50), lookahead=barmerge.lookahead_off)
btcDom_rsi    = request.security(i_btcDomSymbol,  i_sentTF, ta.rsi(close,14), lookahead=barmerge.lookahead_off)

usdtDom_close = request.security(i_usdtDomSymbol, i_sentTF, close, lookahead=barmerge.lookahead_off)
usdtDom_ema20 = request.security(i_usdtDomSymbol, i_sentTF, ta.ema(close,20), lookahead=barmerge.lookahead_off)
usdtDom_ema50 = request.security(i_usdtDomSymbol, i_sentTF, ta.ema(close,50), lookahead=barmerge.lookahead_off)

total_close   = request.security(i_totalMcSymbol, i_sentTF, close, lookahead=barmerge.lookahead_off)
total_ema20   = request.security(i_totalMcSymbol, i_sentTF, ta.ema(close,20), lookahead=barmerge.lookahead_off)
total_ema50   = request.security(i_totalMcSymbol, i_sentTF, ta.ema(close,50), lookahead=barmerge.lookahead_off)
total_rsi     = request.security(i_totalMcSymbol, i_sentTF, ta.rsi(close,14), lookahead=barmerge.lookahead_off)

total3_close  = request.security(i_total3Symbol,  i_sentTF, close, lookahead=barmerge.lookahead_off)
total3_ema20  = request.security(i_total3Symbol,  i_sentTF, ta.ema(close,20), lookahead=barmerge.lookahead_off)
total3_ema50  = request.security(i_total3Symbol,  i_sentTF, ta.ema(close,50), lookahead=barmerge.lookahead_off)

// ── SOURCE 1: Fear & Greed proxy from TOTAL market cap RSI ──
// TOTAL RSI > 70 = greed, < 30 = fear (standard interpretation)
fearGreedScore = total_rsi  // 0-100 range already

// ── SOURCE 2: BTC Dominance trend ──
// Rising BTC.D = bad for alts (alt season ending), good for BTC
btcDomRising  = btcDom_ema20 > btcDom_ema50
btcDomFalling = btcDom_ema20 < btcDom_ema50
btcDomRSI     = btcDom_rsi  // for extreme readings

// ── SOURCE 3: USDT/Stablecoin Dominance trend ──
// Rising USDT.D = risk-off (money fleeing to stables = bearish for crypto)
// Falling USDT.D = risk-on (money flowing into crypto = bullish)
stableDomRising  = usdtDom_ema20 > usdtDom_ema50
stableDomFalling = usdtDom_ema20 < usdtDom_ema50

// ── SOURCE 4: Total Market Cap trend ──
// TOTAL rising = overall crypto bull market
// TOTAL3 rising = alt-specific strength
totalRising   = total_ema20  > total_ema50
totalFalling  = total_ema20  < total_ema50
total3Rising  = total3_ema20 > total3_ema50
total3Falling = total3_ema20 < total3_ema50

// ── Composite Sentiment Score (0-100) ──
// Start at 50 (neutral) and add/subtract based on signals
sentRaw = 50.0
sentRaw := sentRaw + (totalRising      ? 10 : totalFalling      ? -10 : 0)  // TOTAL trend ±10
sentRaw := sentRaw + (stableDomFalling ? 10 : stableDomRising   ? -10 : 0)  // Stable trend ±10 (inverted)
sentRaw := sentRaw + (fearGreedScore - 50) * 0.4                            // F&G proxy (scaled)
sentRaw := sentRaw + (total3Rising     ? 5  : total3Falling     ? -5  : 0)  // Alt strength ±5

// For BTC pairs: BTC.D rising is positive
// For alt pairs: BTC.D rising is negative
if isBTCSymbol
    sentRaw := sentRaw + (btcDomRising  ? 5 : btcDomFalling ? -5 : 0)
else
    sentRaw := sentRaw + (btcDomFalling ? 5 : btcDomRising  ? -5 : 0)

sentRaw := math.max(0, math.min(100, sentRaw))  // clamp 0-100
sentimentScore = math.round(sentRaw)

// ── Sentiment Regime ──
extremeGreed   = sentimentScore >= i_sentExtreme           // contrarian bearish
greed          = sentimentScore >= 60 and sentimentScore < i_sentExtreme
neutral        = sentimentScore >= 40 and sentimentScore < 60
fear           = sentimentScore >= (100 - i_sentExtreme) and sentimentScore < 40
extremeFear    = sentimentScore < (100 - i_sentExtreme)    // contrarian bullish

sentimentLabel = extremeGreed ? "EXTREME GREED" : greed ? "GREED" : neutral ? "NEUTRAL" : fear ? "FEAR" : "EXTREME FEAR"

// ── Sentiment gate for trades ──
// Trend-following logic (not contrarian) — confirms sentiment with bias
// At extreme greed: only allow shorts (contrarian)
// At extreme fear: only allow longs (contrarian)
// In between: follow regular direction
sentOK_long  = not i_useSentiment or not extremeGreed
sentOK_short = not i_useSentiment or not extremeFear

// Bonus: sentiment alignment with trade direction
sentBoostsLong  = i_useSentiment and (fear or extremeFear or (sentimentScore < 50 and stableDomFalling))
sentBoostsShort = i_useSentiment and (greed or extremeGreed or (sentimentScore > 50 and stableDomRising))

// ── Funding Rate Gate ──────────────────────────────────────────────
// Positive funding = crowd long → contrarian bearish bias
// Negative funding = crowd short → contrarian bullish bias
fundingExtremeLong  = i_fundingPct > 0.05    // crowd overlong
fundingExtremeShort = i_fundingPct < -0.03   // crowd overshort

fundingOK_long  = not i_useFunding or not fundingExtremeLong
fundingOK_short = not i_useFunding or not fundingExtremeShort

// ── Open Interest Divergence ───────────────────────────────────────
oiClose = request.security(i_oiSymbol, timeframe.period, close, lookahead=barmerge.lookahead_off)
oiVol   = request.security(i_oiSymbol, timeframe.period, volume, lookahead=barmerge.lookahead_off)
oiProxy = i_oiUseProxy ? oiClose * oiVol : oiVol

oiProxyChange = ta.change(oiProxy, 5)
priceChange   = ta.change(close, 5)

// OI rising with price rising = real breakout (good for longs)
// OI falling with price rising = short cover only (weak — fail long)
oiOKLong  = not i_useOI or (priceChange > 0 ? oiProxyChange > 0 : true)
oiOKShort = not i_useOI or (priceChange < 0 ? oiProxyChange > 0 : true)

// ── Session ─────────────────────────────────────────────────────────
inLondon  = not na(time(timeframe.period, i_sessLondon, i_sessTZ))
inNY      = not na(time(timeframe.period, i_sessNY,     i_sessTZ))
inSession = not i_useSession or (inLondon or inNY)
weekendOK = not i_useSession or not i_skipWeekend or (dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday)

// ── Volatility Regime ───────────────────────────────────────────────
atrPct = atr / close * 100

upMove   = high - high[1]
downMove = low[1] - low
plusDM   = upMove > downMove and upMove > 0 ? upMove : 0.0
minusDM  = downMove > upMove and downMove > 0 ? downMove : 0.0
trVal    = ta.tr(true)
atrRMA   = ta.rma(trVal, i_adxLen)
plusDI   = atrRMA != 0 ? 100 * ta.rma(plusDM, i_adxLen) / atrRMA : 0.0
minusDI  = atrRMA != 0 ? 100 * ta.rma(minusDM, i_adxLen) / atrRMA : 0.0
dx       = (plusDI + minusDI) != 0 ? math.abs(plusDI - minusDI) / (plusDI + minusDI) * 100 : 0.0
adx      = ta.rma(dx, i_adxLen)

volRegimeOK = not i_useVolReg or (atrPct >= i_atrMinPct and adx >= i_adxMin)

// ── News Blackout (Smart Auto + Manual) ──────────────────────────────
// Get current time components (UTC)
curHour   = hour(time, "UTC")
curMin    = minute(time, "UTC")
curDow    = dayofweek(time, "UTC")
curDay    = dayofmonth(time, "UTC")

// Convert blackout window to minutes
totalMins = curHour * 60 + curMin

// FOMC: Wednesdays at 18:00 UTC (rate decisions usually announced at 14:00 ET = 18:00 UTC)
fomcCenterMins = 18 * 60  // 1080
inFOMCWindow   = i_newsBlockFOMC and curDow == dayofweek.wednesday and totalMins >= (fomcCenterMins - i_newsAutoBefore) and totalMins <= (fomcCenterMins + i_newsAutoAfter)

// CPI: 2nd Tuesday of month, 12:30 UTC (8:30 ET)
isSecondWeek   = curDay >= 8 and curDay <= 14
cpiCenterMins  = 12 * 60 + 30  // 750
inCPIWindow    = i_newsBlockCPI and curDow == dayofweek.tuesday and isSecondWeek and totalMins >= (cpiCenterMins - i_newsAutoBefore) and totalMins <= (cpiCenterMins + i_newsAutoAfter)

// NFP: 1st Friday of month, 12:30 UTC (8:30 ET)
isFirstWeek    = curDay >= 1 and curDay <= 7
nfpCenterMins  = 12 * 60 + 30
inNFPWindow    = i_newsBlockNFP and curDow == dayofweek.friday and isFirstWeek and totalMins >= (nfpCenterMins - i_newsAutoBefore) and totalMins <= (nfpCenterMins + i_newsAutoAfter)

// Daily reset (Asia open volatility)
inMidnightWindow = i_newsBlockMidnight and (totalMins <= 15 or totalMins >= 1425)  // 00:00 ±15m

// Weekend open
weekendOpenMins  = 22 * 60  // Sunday 22:00 UTC
inWeekendWindow  = i_newsBlockWeekend and curDow == dayofweek.sunday and totalMins >= (weekendOpenMins - 120) and totalMins <= 1440
inWeekendWindow := inWeekendWindow or (i_newsBlockWeekend and curDow == dayofweek.monday and totalMins <= 120)

autoBlackout = i_newsAuto and (inFOMCWindow or inCPIWindow or inNFPWindow or inMidnightWindow or inWeekendWindow)

// Manual events
inNews1 = time >= i_news1Start and time <= i_news1End
inNews2 = time >= i_news2Start and time <= i_news2End
inNews3 = time >= i_news3Start and time <= i_news3End
manualBlackout = inNews1 or inNews2 or inNews3

inNewsBlackout = i_useNewsBlock and (autoBlackout or manualBlackout)

// Current event name (for dashboard)
newsEventName = inFOMCWindow ? "FOMC" : inCPIWindow ? "CPI" : inNFPWindow ? "NFP" : inMidnightWindow ? "Daily Reset" : inWeekendWindow ? "Weekend Open" : manualBlackout ? "Manual Event" : ""

// ── Candle Confirmation ─────────────────────────────────────────────
bullEngulf = close > open and close > open[1] and open < close[1] and (close - open) > (close[1] - open[1])
bearEngulf = close < open and close < open[1] and open > close[1] and (open - close) > (open[1] - close[1])
bullClose  = close > open and close > (high + low) / 2 + atr * 0.1
bearClose  = close < open and close < (high + low) / 2 - atr * 0.1
candleBull = bullEngulf or bullClose
candleBear = bearEngulf or bearClose

// ── Pattern Engine ──────────────────────────────────────────────────
breakoutRetestBull = i_useStruct and not na(prevExtHigh) and high[1] > prevExtHigh and low <= prevExtHigh and close > prevExtHigh
breakoutRetestBear = i_useStruct and not na(prevExtLow)  and low[1]  < prevExtLow  and high >= prevExtLow  and close < prevExtLow
sweepReversalBull = i_useStruct and ta.barssince(sweepLow)  <= 5 and candleBull
sweepReversalBear = i_useStruct and ta.barssince(sweepHigh) <= 5 and candleBear

patternBull = breakoutRetestBull or sweepReversalBull or (i_useSMC and (inBullOB or inBullFVG))
patternBear = breakoutRetestBear or sweepReversalBear or (i_useSMC and (inBearOB or inBearFVG))

// Global pattern reason string (used in alerts, signal tooltips)
patternReason = breakoutRetestBull or breakoutRetestBear ? "BO+Retest" : sweepReversalBull or sweepReversalBear ? "Sweep+Rev" : inBullOB or inBearOB ? "OB tap" : inBullFVG or inBearFVG ? "FVG fill" : "Confluence"

// ╔══════════════════════════════════════════════════════════════════╗
// ║      WYCKOFF PHASE ENGINE — Accumulation · Manipulation ·        ║
// ║      Distribution + FVG (already detected above)                 ║
// ╚══════════════════════════════════════════════════════════════════╝
// Detects which market phase price is currently in:
//   ACCUMULATION  — sideways range after downtrend, low volatility, vol drying up
//   MANIPULATION  — liquidity sweep / stop hunt before real move (the "spring")
//   MARKUP        — trending up (active bull move)
//   DISTRIBUTION  — sideways range after uptrend, smart money exiting
//   MARKDOWN      — trending down (active bear move)

// Range detection (last 30 bars)
phaseLookback   = 30
rangeHigh       = ta.highest(high, phaseLookback)
rangeLow        = ta.lowest(low,   phaseLookback)
rangeSize       = rangeHigh - rangeLow
rangeMid        = (rangeHigh + rangeLow) / 2
priceInRangePos = (close - rangeLow) / rangeSize  // 0 = at low, 1 = at high

// Volatility contraction (ATR shrinking = consolidation)
atrShrinking    = atr < ta.sma(atr, 20) * 0.85
volShrinking    = volume < ta.sma(volume, 20) * 0.9

// Range bound (small movement vs ATR)
recentRange     = ta.highest(high, 10) - ta.lowest(low, 10)
isRanging       = recentRange < atr * 4

// Trend context (looking back for the phase BEFORE current)
priorTrendDown  = close[phaseLookback] > close[phaseLookback / 2] and ema50[phaseLookback / 2] < ema50[phaseLookback]
priorTrendUp    = close[phaseLookback] < close[phaseLookback / 2] and ema50[phaseLookback / 2] > ema50[phaseLookback]

// ── ACCUMULATION ──
// Sideways range + after downtrend + low vol + price near range low
accumulation = isRanging and atrShrinking and priorTrendDown and priceInRangePos < 0.5 and not ltfTrendBull and not ltfTrendBear

// ── DISTRIBUTION ──
// Sideways range + after uptrend + low vol + price near range high
distribution = isRanging and atrShrinking and priorTrendUp and priceInRangePos > 0.5 and not ltfTrendBull and not ltfTrendBear

// ── MANIPULATION (Spring / Upthrust) ──
// Liquidity sweep that quickly reverses — the "trap" before the real move
manipulationBull = sweepLow  and volSpike and (close > open or close > low + (high - low) * 0.6)
manipulationBear = sweepHigh and volSpike and (close < open or close < high - (high - low) * 0.6)
manipulation     = manipulationBull or manipulationBear

// ── MARKUP / MARKDOWN ──
markup    = ltfTrendBull and not isRanging
markdown  = ltfTrendBear and not isRanging

// ── Current Phase Resolver ──
// Priority: Manipulation > Accumulation > Distribution > Markup > Markdown > Neutral
currentPhase = manipulation  ? "MANIPULATION" : accumulation ? "ACCUMULATION" : distribution ? "DISTRIBUTION" : markup       ? "MARKUP"       : markdown     ? "MARKDOWN"     : "NEUTRAL"

phaseColor   = manipulation  ? color.new(#ff9800, 0)  : accumulation ? color.new(#00bcd4, 0)  : distribution ? color.new(#e91e63, 0)  : markup       ? color.new(#00e676, 0)  : markdown     ? color.new(#ff1744, 0)  : color.new(#9e9e9e, 0)

// Boost signal confidence when entering in the RIGHT phase
// Long is best in: Markup (continuation), late Accumulation, after Manipulation Bull
// Short is best in: Markdown (continuation), late Distribution, after Manipulation Bear
phaseFavorsLong  = markup or accumulation or manipulationBull
phaseFavorsShort = markdown or distribution or manipulationBear

// ╔══════════════════════════════════════════════════════════════════╗
// ║          CONFLUENCE COUNT & SIGNAL GATE                          ║
// ╚══════════════════════════════════════════════════════════════════╝
// Each confirmation counted only if its master switch is ON
confLong1 = i_useRSI     and rsiConfBull
confLong2 = i_useMACD    and macdConfBull
confLong3 = i_useVol     and volConfirm
confLong4 = i_useStruct  and structureBias >= 0
confLong5 = i_useSession and inSession
confLong6 = i_useCVD     and cvdConfBull
confLong7 = i_useHTFsr   and htfsrConfLong
confLong8 = i_useVolReg  and volRegimeOK

confShort1 = i_useRSI     and rsiConfBear
confShort2 = i_useMACD    and macdConfBear
confShort3 = i_useVol     and volConfirm
confShort4 = i_useStruct  and structureBias <= 0
confShort5 = i_useSession and inSession
confShort6 = i_useCVD     and cvdConfBear
confShort7 = i_useHTFsr   and htfsrConfShort
confShort8 = i_useVolReg  and volRegimeOK

longConfCount  = (confLong1?1:0) + (confLong2?1:0) + (confLong3?1:0) + (confLong4?1:0) + (confLong5?1:0) + (confLong6?1:0) + (confLong7?1:0) + (confLong8?1:0)
shortConfCount = (confShort1?1:0) + (confShort2?1:0) + (confShort3?1:0) + (confShort4?1:0) + (confShort5?1:0) + (confShort6?1:0) + (confShort7?1:0) + (confShort8?1:0)

// Active modules count (for normalization)
activeModules = (i_useRSI?1:0) + (i_useMACD?1:0) + (i_useVol?1:0) + (i_useStruct?1:0) + (i_useSession?1:0) + (i_useCVD?1:0) + (i_useHTFsr?1:0) + (i_useVolReg?1:0)

// ── Preset-aware core conditions ──
// Strict: needs ALL 3 MTF + strong trend
// Balanced: needs 2/3 MTF + EMA stack
// Aggressive: needs 2/3 MTF (no slope requirement)
// Scalping: needs 1/3 MTF (just LTF trend matters) + relaxed candle
// Aggressive Scalping: just needs LTF trend, MTF optional
isStrict     = i_preset == "Strict (sniper)"
isAggressive = i_preset == "Aggressive" or isAggScalp

// MTF requirement adapts to preset
mtfPassLong  = not i_useMTF or (isAggScalp ? mtfBullScore >= 1 : isScalping ? mtfBullScore >= 1 : isAggressive ? mtfBullScore >= 2 : isStrict ? mtfBullScore == 3 : mtfBullScore >= 2)
mtfPassShort = not i_useMTF or (isAggScalp ? mtfBearScore >= 1 : isScalping ? mtfBearScore >= 1 : isAggressive ? mtfBearScore >= 2 : isStrict ? mtfBearScore == 3 : mtfBearScore >= 2)

// Trend requirement adapts to preset
trendPassLong  = isScalping or isAggressive ? emaBull : ltfTrendBull
trendPassShort = isScalping or isAggressive ? emaBear : ltfTrendBear

// Candle requirement - scalping doesn't require engulfing, just direction
candlePassLong  = isAggScalp ? close > open : isScalping ? close > open : candleBull
candlePassShort = isAggScalp ? close < open : isScalping ? close < open : candleBear

// Core conditions (preset-adaptive)
longCore  = trendPassLong  and mtfPassLong  and patternBull and candlePassLong  and btcOKLong  and fundingOK_long  and oiOKLong  and sentOK_long  and weekendOK and not inNewsBlackout and barstate.isconfirmed
shortCore = trendPassShort and mtfPassShort and patternBear and candlePassShort and btcOKShort and fundingOK_short and oiOKShort and sentOK_short and weekendOK and not inNewsBlackout and barstate.isconfirmed

// ── Confidence Score (0-100) ────────────────────────────────────────
// Weights: MTF 25%, Pattern 15%, Candle 10%, Confluences 30%, HTF S/R 10%, Sentiment 10%
confLong  = 0
confShort = 0
confLong  := (not i_useMTF ? 0 : mtfFullBull ? 25 : mtfBullScore * 8) + (patternBull ? 15 : 0) + (candleBull ? 10 : 0) + (longConfCount - (confLong7 ? 1 : 0)) * 3 + (i_useHTFsr and nearHTFsupport ? 10 : 0) + (i_useSentiment ? (sentBoostsLong ? 10 : sentOK_long ? 5 : 0) : 0)
confShort := (not i_useMTF ? 0 : mtfFullBear ? 25 : mtfBearScore * 8) + (patternBear ? 15 : 0) + (candleBear ? 10 : 0) + (shortConfCount - (confShort7 ? 1 : 0)) * 3 + (i_useHTFsr and nearHTFresist ? 10 : 0) + (i_useSentiment ? (sentBoostsShort ? 10 : sentOK_short ? 5 : 0) : 0)

confLong  := math.min(confLong, 100)
confShort := math.min(confShort, 100)

// ── Risk Calculations ───────────────────────────────────────────────
// Adaptive ATR multiplier
// Adaptive ATR multiplier - scalping uses tighter stops
atrSLmult = isScalping ? (isAggScalp ? 1.0 : 1.3) : (i_adaptiveATR ? (isHighVol ? i_atrHighMult : isLowVol ? i_atrLowMult : 2.0) : 2.0)

slDistATR = atr * atrSLmult
longSL_struct = bullOBValid ? bullOB_bot - atr * i_slBufATR : not na(lastExtLow)  ? lastExtLow  - atr * i_slBufATR : close - slDistATR
shortSL_struct = bearOBValid ? bearOB_top + atr * i_slBufATR : not na(lastExtHigh) ? lastExtHigh + atr * i_slBufATR : close + slDistATR

// Use structure SL if tighter than ATR SL (better R:R) else ATR
longSL  = math.max(longSL_struct,  close - slDistATR * 1.5)
shortSL = math.min(shortSL_struct, close + slDistATR * 1.5)

// Risk distance
longRiskDist  = close - longSL
shortRiskDist = shortSL - close

// TP targets
longTP1  = close + longRiskDist  * i_tp1R
longTP2  = close + longRiskDist  * i_tp2R
shortTP1 = close - shortRiskDist * i_tp1R
shortTP2 = close - shortRiskDist * i_tp2R

// Primary TP (for non-multi-TP mode)
longTP_simple  = not na(lastExtHigh) and lastExtHigh > close ? lastExtHigh : close + longRiskDist * minRR
shortTP_simple = not na(lastExtLow)  and lastExtLow  < close ? lastExtLow  : close - shortRiskDist * minRR

longTP1_plan  = i_useMultiTP ? longTP1 : longTP_simple
longTP2_plan  = i_useMultiTP ? longTP2 : longTP_simple
shortTP1_plan = i_useMultiTP ? shortTP1 : shortTP_simple
shortTP2_plan = i_useMultiTP ? shortTP2 : shortTP_simple

longRR  = longRiskDist  > 0 ? (longTP_simple - close) / longRiskDist  : 0
shortRR = shortRiskDist > 0 ? (close - shortTP_simple) / shortRiskDist : 0

rrOK_long  = longRR  >= minRR
rrOK_short = shortRR >= minRR

// ╔══════════════════════════════════════════════════════════════════╗
// ║          DISCIPLINE & PERFORMANCE TRACKING                       ║
// ╚══════════════════════════════════════════════════════════════════╝

// Daily loss tracking
var float dayStartEquity = strategy.initial_capital
var int   prevDay        = na

newDay = not na(prevDay) and prevDay != dayofmonth
if newDay
    dayStartEquity := strategy.equity
prevDay := dayofmonth

dailyDD_pct  = (strategy.equity - dayStartEquity) / dayStartEquity * 100
dailyDD_hit  = i_useDailyDD and dailyDD_pct <= -i_maxDailyDD

// Streak tracking
var int winStreakC  = 0
var int lossStreakC = 0
var float lastClosedPnL = 0.0

if strategy.closedtrades > 0 and strategy.closedtrades > strategy.closedtrades[1]
    lastClosedPnL := strategy.closedtrades.profit(strategy.closedtrades - 1)
    if lastClosedPnL > 0
        winStreakC  := winStreakC + 1
        lossStreakC := 0
    else if lastClosedPnL < 0
        lossStreakC := lossStreakC + 1
        winStreakC  := 0

// Size multiplier from streaks
streakMult = 1.0
if i_useStreakAdj
    if lossStreakC >= i_lossStreak
        streakMult := 1.0 - i_lossStreakReduce / 100
    else if winStreakC >= i_winStreak
        streakMult := 1.0 + i_winStreakAdd / 100

// Cooldown & daily cap
var int lastSignalBar = na
var int tradesToday   = 0

if newDay
    tradesToday := 0

cooldownOK  = na(lastSignalBar) or (bar_index - lastSignalBar) >= cooldown
dailyCapOK  = tradesToday < maxPerDay
inDateRange = not i_useDate or (time >= i_dateStart and time <= i_dateEnd)

// ── FINAL SIGNAL GATES ──────────────────────────────────────────────
longSignal  = strategy.position_size == 0 and i_allowLong  and longCore  and longConfCount  >= minConfirm and rrOK_long  and confLong  >= minConf and cooldownOK and dailyCapOK and inDateRange and not dailyDD_hit and htfsrConfLong
shortSignal = strategy.position_size == 0 and i_allowShort and shortCore and shortConfCount >= minConfirm and rrOK_short and confShort >= minConf and cooldownOK and dailyCapOK and inDateRange and not dailyDD_hit and htfsrConfShort

if longSignal or shortSignal
    lastSignalBar := bar_index
    tradesToday   := tradesToday + 1

// ╔══════════════════════════════════════════════════════════════════╗
// ║                    STRATEGY EXECUTION                            ║
// ╚══════════════════════════════════════════════════════════════════╝
// Position sizing with streak adjustment
riskAmount = strategy.equity * (i_riskPct / 100) * streakMult
qtyLong    = longRiskDist  > 0 ? riskAmount / longRiskDist  : na
qtyShort   = shortRiskDist > 0 ? riskAmount / shortRiskDist : na

// Entries
if longSignal and strategy.position_size == 0
    strategy.entry("LONG", strategy.long, qty=qtyLong)
    if i_useMultiTP
        strategy.exit("TP1 L", from_entry="LONG", qty_percent=i_tp1Pct, limit=longTP1, stop=longSL)
        strategy.exit("TP2 L", from_entry="LONG", qty_percent=i_tp2Pct, limit=longTP2, stop=longSL)
        // Runner managed by trailing stop block below
    else
        strategy.exit("Exit L", from_entry="LONG", stop=longSL, limit=longTP_simple)

if shortSignal and strategy.position_size == 0
    strategy.entry("SHORT", strategy.short, qty=qtyShort)
    if i_useMultiTP
        strategy.exit("TP1 S", from_entry="SHORT", qty_percent=i_tp1Pct, limit=shortTP1, stop=shortSL)
        strategy.exit("TP2 S", from_entry="SHORT", qty_percent=i_tp2Pct, limit=shortTP2, stop=shortSL)
    else
        strategy.exit("Exit S", from_entry="SHORT", stop=shortSL, limit=shortTP_simple)

// ── Partial TP at 1R + Move SL to Breakeven ─────────────────────────
var bool longBE_done  = false
var bool shortBE_done = false

if i_usePartialTP and strategy.position_size > 0
    avgEntry = strategy.position_avg_price
    riskDist = avgEntry - longSL
    if not longBE_done and high >= avgEntry + riskDist  // hit 1R
        // Move stop to breakeven for remainder
        strategy.exit("BE L", from_entry="LONG", stop=avgEntry)
        longBE_done := true
else
    longBE_done := false

if i_usePartialTP and strategy.position_size < 0
    avgEntry = strategy.position_avg_price
    riskDist = shortSL - avgEntry
    if not shortBE_done and low <= avgEntry - riskDist  // hit 1R
        strategy.exit("BE S", from_entry="SHORT", stop=avgEntry)
        shortBE_done := true
else
    shortBE_done := false

// ── Trailing Stop (runner / non-multi-TP) ──────────────────────────
var float longTrail  = na
var float shortTrail = na

if strategy.position_size > 0
    newTrail = close - atr * i_trailATR
    longTrail := na(longTrail) ? newTrail : math.max(longTrail, newTrail)
    if close < longTrail
        strategy.close("LONG", comment="Trail")
else
    longTrail := na

if strategy.position_size < 0
    newTrail = close + atr * i_trailATR
    shortTrail := na(shortTrail) ? newTrail : math.min(shortTrail, newTrail)
    if close > shortTrail
        strategy.close("SHORT", comment="Trail")
else
    shortTrail := na

// ╔══════════════════════════════════════════════════════════════════╗
// ║          SHARPE RATIO APPROXIMATION                              ║
// ╚══════════════════════════════════════════════════════════════════╝
var float prevEquity = strategy.initial_capital
equityReturn = strategy.equity != prevEquity ? (strategy.equity - prevEquity) / prevEquity : 0.0
prevEquity := strategy.equity

returnsMA  = ta.sma(equityReturn, 100)
returnsStd = ta.stdev(equityReturn, 100)
sharpeApprox = returnsStd > 0 ? returnsMA / returnsStd * math.sqrt(252) : 0.0

// ╔══════════════════════════════════════════════════════════════════╗
// ║          🧠 ADVANCED ANALYTICS ENGINE                            ║
// ║   Statistical models · Expected Value · Risk math · Regime       ║
// ╚══════════════════════════════════════════════════════════════════╝

// ── STATISTICAL MODELS ────────────────────────────────────────────
// Z-Score: how many standard deviations away from mean (extreme readings)
zScoreLen   = 50
priceMA50   = ta.sma(close, zScoreLen)
priceStd50  = ta.stdev(close, zScoreLen)
zScore      = priceStd50 > 0 ? (close - priceMA50) / priceStd50 : 0.0

// Bollinger %B (where in the band is price)
bbLen     = 20
bbStdMult = 2.0
bbMid     = ta.sma(close, bbLen)
bbUpper   = bbMid + bbStdMult * ta.stdev(close, bbLen)
bbLower   = bbMid - bbStdMult * ta.stdev(close, bbLen)
bbPctB    = (bbUpper - bbLower) > 0 ? (close - bbLower) / (bbUpper - bbLower) : 0.5

// Hurst Exponent proxy (trending vs mean-reverting market detector)
// H > 0.5 = trending, H < 0.5 = mean-reverting, H = 0.5 = random walk
hurstLen     = 100
priceLog     = math.log(close)
hurstMean    = ta.sma(priceLog, hurstLen)
hurstDev     = priceLog - hurstMean
hurstRange   = ta.highest(hurstDev, hurstLen) - ta.lowest(hurstDev, hurstLen)
hurstStd     = ta.stdev(priceLog, hurstLen)
hurstRatio   = hurstStd > 0 ? hurstRange / hurstStd : 0.0
hurstApprox  = hurstRatio > 0 ? math.log(hurstRatio) / math.log(hurstLen) : 0.5
marketRegime = hurstApprox > 0.55 ? "TRENDING" : hurstApprox < 0.45 ? "MEAN REVERT" : "RANDOM"

// ── EXPECTED VALUE & KELLY ────────────────────────────────────────
// Live calculation from backtest history
winRate_live = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades : 0.5
lossRate_live = 1.0 - winRate_live

avgWin_live  = strategy.wintrades > 0   ? strategy.grossprofit / strategy.wintrades : 0.0
avgLoss_live = strategy.losstrades > 0  ? math.abs(strategy.grossloss) / strategy.losstrades : 1.0

// Expected Value per trade (in $)
expectedValue = (winRate_live * avgWin_live) - (lossRate_live * avgLoss_live)

// Kelly Criterion: optimal fraction of capital to risk
// f* = (bp - q) / b  where b = avgWin/avgLoss, p = winrate, q = lossrate
kellyB        = avgLoss_live > 0 ? avgWin_live / avgLoss_live : 1.0
kellyFraction = kellyB > 0 ? (kellyB * winRate_live - lossRate_live) / kellyB : 0.0
kellyFraction := math.max(0, math.min(kellyFraction, 0.25))  // cap at 25% (half-Kelly safer)
kellyHalfFrac = kellyFraction * 0.5  // half-Kelly is industry standard

// ── DEEP BACKTEST STATS ───────────────────────────────────────────
// Sortino (downside deviation only)
downReturns       = equityReturn < 0 ? equityReturn : 0.0
downStd           = ta.stdev(downReturns, 100)
sortinoApprox     = downStd > 0 ? returnsMA / downStd * math.sqrt(252) : 0.0

// Calmar Ratio = annual return / max DD
maxDD_pct         = strategy.max_drawdown / strategy.initial_capital * 100
annualReturn      = strategy.netprofit / strategy.initial_capital * 100
calmarRatio       = maxDD_pct > 0 ? annualReturn / maxDD_pct : 0.0

// Recovery Factor = net profit / max DD
recoveryFactor    = strategy.max_drawdown > 0 ? strategy.netprofit / strategy.max_drawdown : 0.0

// Expectancy per trade
expectancyPer     = strategy.closedtrades > 0 ? strategy.netprofit / strategy.closedtrades : 0.0

// ── RISK MODELS ──────────────────────────────────────────────────
// Equity curve MA filter - if equity drops below MA, reduce risk
var float equityMA = 0.0
equityMA := ta.sma(strategy.equity, 50)
equityBelowMA = strategy.equity < equityMA
equityCurveOK = not equityBelowMA

// Max DD circuit breaker (script-level, additive to daily)
maxDDshutdown_pct = 15.0  // hardcoded safety
maxDDshutdown = maxDD_pct >= maxDDshutdown_pct

// ── MARKET REGIME CLASSIFIER (4 regimes) ──────────────────────────
// Combines trend direction + volatility level
regimeBullTrend  = ltfTrendBull and atrPct > 0.5
regimeBearTrend  = ltfTrendBear and atrPct > 0.5
regimeHighVolRng = not ltfTrendBull and not ltfTrendBear and atrPct > 0.8
regimeLowVolRng  = not ltfTrendBull and not ltfTrendBear and atrPct <= 0.8

currentRegime = regimeBullTrend ? "BULL TREND" : regimeBearTrend ? "BEAR TREND" : regimeHighVolRng ? "HIGH VOL RANGE" : "LOW VOL RANGE"

// ── ANTI-REVENGE TRADE PROTECTION ─────────────────────────────────
// Block new trades for N bars after a loss (preset-aware)
revengeBlockBars = isScalping ? 3 : 8
var int lastLossBar = na
if strategy.closedtrades > 0 and strategy.closedtrades > strategy.closedtrades[1] and lastClosedPnL < 0
    lastLossBar := bar_index

antiRevengeOK = na(lastLossBar) or (bar_index - lastLossBar) >= revengeBlockBars

// ── ACCUMULATION / HYBRID ENTRY ─────────────────────────────────
// Hybrid: initial entry + 1 pyramid add at +1R confirmation
g_accum = "📥 Accumulation Strategy"
i_useAccum     = input.bool(false, "Enable Hybrid Accumulation (pyramid +1 at +1R)", group=g_accum,
     tooltip="Adds ONE more position when trade reaches +1R profit. Total max exposure = 1.5x original.")
i_accumPct     = input.float(50, "Pyramid add size (% of original)", group=g_accum, step=10, minval=20, maxval=100)

var bool longPyramidDone = false
var bool shortPyramidDone = false

if strategy.position_size > 0 and i_useAccum and not longPyramidDone
    avgEntry = strategy.position_avg_price
    riskDist = avgEntry - longSL
    if high >= avgEntry + riskDist
        strategy.entry("LONG+", strategy.long, qty=qtyLong * (i_accumPct/100), comment="Pyramid+1R")
        longPyramidDone := true

if strategy.position_size < 0 and i_useAccum and not shortPyramidDone
    avgEntry = strategy.position_avg_price
    riskDist = shortSL - avgEntry
    if low <= avgEntry - riskDist
        strategy.entry("SHORT+", strategy.short, qty=qtyShort * (i_accumPct/100), comment="Pyramid+1R")
        shortPyramidDone := true

// Reset pyramid flags when position closes
if strategy.position_size == 0
    longPyramidDone  := false
    shortPyramidDone := false

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       VISUALIZATION                              ║
// ╚══════════════════════════════════════════════════════════════════╝

// ── Wyckoff Phase Background Tints (very subtle) ─────────────────────
bgcolor(i_showWyckoff and accumulation     ? color.new(#00bcd4, 92) : na, title="Accumulation")
bgcolor(i_showWyckoff and distribution     ? color.new(#e91e63, 92) : na, title="Distribution")
bgcolor(i_showWyckoff and manipulationBull ? color.new(#ff9800, 80) : na, title="Manipulation Bull")
bgcolor(i_showWyckoff and manipulationBear ? color.new(#ff9800, 80) : na, title="Manipulation Bear")
bgcolor(i_showWyckoff and markup           ? color.new(#00e676, 96) : na, title="Markup")
bgcolor(i_showWyckoff and markdown         ? color.new(#ff1744, 96) : na, title="Markdown")

// ── Phase Change Label (ONLY MAJOR TRANSITIONS) ──────────────────────
// Show label only when phase changes to a DIFFERENT major phase AND cooldown OK
// Cooldown prevents spam — minimum 20 bars between phase labels
var string prevPhase     = "NEUTRAL"
var int    lastPhaseBar  = na

phaseCooldownBars = 20  // minimum bars between phase labels
phaseCooldownOK   = na(lastPhaseBar) or (bar_index - lastPhaseBar) >= phaseCooldownBars

// Only major transitions worth labeling:
// 1. Anything → Manipulation (always show — most actionable)
// 2. Accumulation → Markup (start of bull move)
// 3. Distribution → Markdown (start of bear move)
// 4. Markup → Distribution (top forming)
// 5. Markdown → Accumulation (bottom forming)
majorTransition =
     (manipulation) or
     (prevPhase == "ACCUMULATION" and markup) or
     (prevPhase == "DISTRIBUTION" and markdown) or
     (prevPhase == "MARKUP"       and distribution) or
     (prevPhase == "MARKDOWN"     and accumulation)

showPhaseLabel = currentPhase != prevPhase and currentPhase != "NEUTRAL" and majorTransition and phaseCooldownOK

if showPhaseLabel and i_showPhaseLbl and barstate.isconfirmed
    phaseIcon = manipulation ? "⚠" : accumulation ? "ACC" : distribution ? "DIST" : markup ? "🚀" : markdown ? "📉" : ""

    // Educational tooltip explaining WHY this phase fired
    phaseTooltip = manipulation ?
         "⚠ MANIPULATION PHASE\n\nWHAT: Smart money swept liquidity (stop hunt) creating a 'spring' or 'upthrust'.\n\nWHY HERE:\n• Liquidity sweep detected at external pivot\n• Volume spike confirmed institutional activity\n• Strong reversal candle formed\n\nWHAT TO DO:\n" + (manipulationBull ? "• Watch for LONG entry as price rejects lower levels\n• SL below the sweep low\n• This is often the BEST long entry of the move" : "• Watch for SHORT entry as price rejects higher levels\n• SL above the sweep high\n• This is often the BEST short entry of the move") :
         accumulation ?
         "ACCUMULATION PHASE\n\nWHAT: Smart money is quietly buying after a downtrend. Range-bound with declining volatility.\n\nWHY HERE:\n• Sideways for 10+ bars (ranging)\n• ATR shrinking (volatility contraction)\n• Prior trend was DOWN\n• Price in lower half of range\n\nWHAT TO DO:\n• DO NOT short here - downtrend is exhausting\n• Wait for breakout above range high\n• Look for sweep+reversal (spring) for early entry\n• Markup phase usually follows" :
         distribution ?
         "DISTRIBUTION PHASE\n\nWHAT: Smart money quietly selling after an uptrend. Range-bound with declining volatility.\n\nWHY HERE:\n• Sideways for 10+ bars\n• ATR shrinking\n• Prior trend was UP\n• Price in upper half of range\n\nWHAT TO DO:\n• DO NOT long here - uptrend is exhausting\n• Wait for breakdown below range low\n• Look for sweep+reversal (upthrust) for early short\n• Markdown phase usually follows" :
         markup ?
         "🚀 MARKUP PHASE\n\nWHAT: Active bull trend after accumulation. Smart money in profit mode.\n\nWHY HERE:\n• EMA stack aligned bullish (20>50>200)\n• EMA slope rising\n• Price breaking ranges to upside\n\nWHAT TO DO:\n• Buy pullbacks to demand zones (OBs, FVGs)\n• Trail stops aggressively\n• Look for distribution signs to exit longs" :
         markdown ?
         "📉 MARKDOWN PHASE\n\nWHAT: Active bear trend after distribution. Smart money in profit mode (short).\n\nWHY HERE:\n• EMA stack aligned bearish (20<50<200)\n• EMA slope falling\n• Price breaking ranges to downside\n\nWHAT TO DO:\n• Sell rallies to supply zones (OBs, FVGs)\n• Trail stops aggressively\n• Look for accumulation signs to exit shorts" :
         "Market phase neutral - no clear direction"

    label.new(bar_index,
         manipulation ? (manipulationBull ? low - atr * 0.8 : high + atr * 0.8) :
         distribution or markdown ? high + atr * 0.8 : low - atr * 0.8,
         phaseIcon + " " + currentPhase,
         color=phaseColor,
         textcolor=accumulation or markup ? color.black : color.white,
         style=(distribution or markdown or manipulationBear) ? label.style_label_down : label.style_label_up,
         size=size.small,
         tooltip=phaseTooltip)
    lastPhaseBar := bar_index

if currentPhase != prevPhase and currentPhase != "NEUTRAL"
    prevPhase := currentPhase

plot(i_showEMA ? ema20  : na, "EMA 20",  color=color.new(#26c6da, 0), linewidth=1)
plot(i_showEMA ? ema50  : na, "EMA 50",  color=color.new(#ffa726, 0), linewidth=1)
plot(i_showEMA ? ema200 : na, "EMA 200", color=color.new(#ef5350, 0), linewidth=2)

plotshape(i_showStruct and not na(extHigh), title="Ext High",
     style=shape.triangledown, location=location.abovebar,
     color=color.new(#ef5350, 40), size=size.tiny, offset=-i_pivotLen)
plotshape(i_showStruct and not na(extLow), title="Ext Low",
     style=shape.triangleup, location=location.belowbar,
     color=color.new(#26a69a, 40), size=size.tiny, offset=-i_pivotLen)

var line lineExtH = na
var line lineExtL = na

if i_showStruct and not na(extHigh)
    line.delete(lineExtH)
    lineExtH := line.new(bar_index - i_pivotLen, extHigh, bar_index + 5, extHigh,
         color=color.new(#ef5350, 50), style=line.style_dashed, width=1)
if i_showStruct and not na(extLow)
    line.delete(lineExtL)
    lineExtL := line.new(bar_index - i_pivotLen, extLow, bar_index + 5, extLow,
         color=color.new(#26a69a, 50), style=line.style_dashed, width=1)
if not i_showStruct and not na(lineExtH)
    line.delete(lineExtH)
    lineExtH := na
if not i_showStruct and not na(lineExtL)
    line.delete(lineExtL)
    lineExtL := na

if i_showStruct and chochBull
    label.new(bar_index, low - atr * 0.5, "CHoCH ↑",
         color=color.new(#00e676, 0), textcolor=color.black,
         style=label.style_label_up, size=sizeLabel,
         tooltip="🔄 CHoCH BULLISH (Change of Character)\n\nWHAT: Market structure has broken UP. Previous lower highs are no longer being respected — buyers are taking control.\n\nWHY HERE:\n• Price closed ABOVE the last external swing high\n• Break distance > 0.5× ATR (filtered, not noise)\n• Prior structure was bearish (LH/LL) — this BREAKS that\n• Confirmed bar close (not just a wick)\n\nWHAT TO DO:\n• Bearish trend likely ENDING\n• Look for LONG entry on next pullback to OB/FVG\n• SL below the swing low that confirmed the CHoCH\n• High probability reversal — institutional buying detected")
if i_showStruct and chochBear
    label.new(bar_index, high + atr * 0.5, "CHoCH ↓",
         color=color.new(#ff1744, 0), textcolor=color.white,
         style=label.style_label_down, size=sizeLabel,
         tooltip="🔄 CHoCH BEARISH (Change of Character)\n\nWHAT: Market structure has broken DOWN. Previous higher lows are no longer being respected — sellers are taking control.\n\nWHY HERE:\n• Price closed BELOW the last external swing low\n• Break distance > 0.5× ATR (filtered, not noise)\n• Prior structure was bullish (HH/HL) — this BREAKS that\n• Confirmed bar close (not just a wick)\n\nWHAT TO DO:\n• Bullish trend likely ENDING\n• Look for SHORT entry on next pullback to OB/FVG\n• SL above the swing high that confirmed the CHoCH\n• High probability reversal — institutional selling detected")

plotshape(sweepHigh, title="Sweep High", style=shape.xcross,
     location=location.abovebar, color=color.new(#ff9800, 0), size=size.tiny)
plotshape(sweepLow,  title="Sweep Low",  style=shape.xcross,
     location=location.belowbar, color=color.new(#7b1fa2, 0), size=size.tiny)

var box   bullOBBox   = na
var label bullOBTip   = na
var box   bearOBBox   = na
var label bearOBTip   = na

if i_showOB and bullOBValid and barstate.islast
    box.delete(bullOBBox)
    label.delete(bullOBTip)
    bullOBBox := box.new(bullOB_bar, bullOB_top, bar_index + 5, bullOB_bot,
         border_color=color.new(#26a69a, 0), border_width=1,
         bgcolor=color.new(#26a69a, 85))
    bullOBTip := label.new(bar_index + 5, (bullOB_top + bullOB_bot) / 2, "🟢 BULL OB",
         color=color.new(#26a69a, 0), textcolor=color.white,
         style=label.style_label_left, size=size.tiny,
         tooltip="🟦 BULLISH ORDER BLOCK\n\nWHAT: The LAST bearish candle before a strong bullish impulse. This is where institutions placed buy orders.\n\nWHY HERE:\n• A bullish impulse candle followed (move > " + str.tostring(i_obImpulse) + "× ATR)\n• Previous candle was bearish (the OB)\n• Block is still FRESH (price hasn't returned to it yet)\n• Within max age of " + str.tostring(i_obMaxBars) + " bars\n\nLEVELS:\n• Top: " + str.tostring(bullOB_top, format.mintick) + "\n• Bot: " + str.tostring(bullOB_bot, format.mintick) + "\n\nWHAT TO DO:\n• HIGH PROBABILITY long entry zone\n• Wait for price to retrace into this box\n• SL just below box bottom\n• Look for bullish rejection candle in the zone")

if i_showOB and bearOBValid and barstate.islast
    box.delete(bearOBBox)
    label.delete(bearOBTip)
    bearOBBox := box.new(bearOB_bar, bearOB_top, bar_index + 5, bearOB_bot,
         border_color=color.new(#ef5350, 0), border_width=1,
         bgcolor=color.new(#ef5350, 85))
    bearOBTip := label.new(bar_index + 5, (bearOB_top + bearOB_bot) / 2, "🔴 BEAR OB",
         color=color.new(#ef5350, 0), textcolor=color.white,
         style=label.style_label_left, size=size.tiny,
         tooltip="🟥 BEARISH ORDER BLOCK\n\nWHAT: The LAST bullish candle before a strong bearish impulse. This is where institutions placed sell orders.\n\nWHY HERE:\n• A bearish impulse candle followed (move > " + str.tostring(i_obImpulse) + "× ATR)\n• Previous candle was bullish (the OB)\n• Block is still FRESH (price hasn't returned to it yet)\n• Within max age of " + str.tostring(i_obMaxBars) + " bars\n\nLEVELS:\n• Top: " + str.tostring(bearOB_top, format.mintick) + "\n• Bot: " + str.tostring(bearOB_bot, format.mintick) + "\n\nWHAT TO DO:\n• HIGH PROBABILITY short entry zone\n• Wait for price to retrace into this box\n• SL just above box top\n• Look for bearish rejection candle in the zone")

if barstate.islast and (not i_showOB or not bullOBValid) and not na(bullOBBox)
    box.delete(bullOBBox)
    label.delete(bullOBTip)
    bullOBBox := na
    bullOBTip := na

if barstate.islast and (not i_showOB or not bearOBValid) and not na(bearOBBox)
    box.delete(bearOBBox)
    label.delete(bearOBTip)
    bearOBBox := na
    bearOBTip := na

var box   bullFVGBox  = na
var label bullFVGTip  = na
var box   bearFVGBox  = na
var label bearFVGTip  = na

if i_showFVG and bullFVG_active and barstate.islast
    if bullFVG or na(bullFVGBox) or na(bullFVGTip)
        box.delete(bullFVGBox)
        label.delete(bullFVGTip)
        bullFVGBox := box.new(not na(bullFVG_bar) ? bullFVG_bar : bar_index - 2, bullFVG_top, bar_index + 5, bullFVG_bot,
             border_color=color.new(#00bcd4, 30), border_width=1,
             bgcolor=color.new(#00bcd4, 90))
        bullFVGTip := label.new(bar_index + 5, (bullFVG_top + bullFVG_bot) / 2, "BULL FVG",
             color=color.new(#00bcd4, 0), textcolor=color.white,
             style=label.style_label_left, size=size.tiny,
             tooltip="⬜ BULLISH FAIR VALUE GAP (FVG)\n\nWHAT: A 3-candle imbalance where price moved so fast it left a gap. Institutions left unfilled orders here — price often returns to 'fill' this gap.\n\nWHY HERE:\n• Current low > high of 2 candles ago\n• Gap size > " + str.tostring(i_fvgMinATR) + "× ATR\n• Not yet filled by price retracement\n\nLEVELS:\n• Top: " + str.tostring(bullFVG_top, format.mintick) + "\n• Bot: " + str.tostring(bullFVG_bot, format.mintick) + "\n\nWHAT TO DO:\n• Magnet for price - high chance of retest\n• Good LONG zone if it aligns with bullish bias\n• Once filled, FVG is invalidated\n• Combine with OB for strongest entries")
    else
        box.set_right(bullFVGBox, bar_index + 5)
        label.set_x(bullFVGTip, bar_index + 5)
        label.set_y(bullFVGTip, (bullFVG_top + bullFVG_bot) / 2)
if i_showFVG and bearFVG_active and barstate.islast
    if bearFVG or na(bearFVGBox) or na(bearFVGTip)
        box.delete(bearFVGBox)
        label.delete(bearFVGTip)
        bearFVGBox := box.new(not na(bearFVG_bar) ? bearFVG_bar : bar_index - 2, bearFVG_top, bar_index + 5, bearFVG_bot,
             border_color=color.new(#ff9800, 30), border_width=1,
             bgcolor=color.new(#ff9800, 90))
        bearFVGTip := label.new(bar_index + 5, (bearFVG_top + bearFVG_bot) / 2, "BEAR FVG",
             color=color.new(#ff9800, 0), textcolor=color.white,
             style=label.style_label_left, size=size.tiny,
             tooltip="⬜ BEARISH FAIR VALUE GAP (FVG)\n\nWHAT: A 3-candle imbalance where price dropped so fast it left a gap. Institutions left unfilled sell orders here.\n\nWHY HERE:\n• Current high < low of 2 candles ago\n• Gap size > " + str.tostring(i_fvgMinATR) + "× ATR\n• Not yet filled by price retracement\n\nLEVELS:\n• Top: " + str.tostring(bearFVG_top, format.mintick) + "\n• Bot: " + str.tostring(bearFVG_bot, format.mintick) + "\n\nWHAT TO DO:\n• Magnet for price - high chance of retest\n• Good SHORT zone if it aligns with bearish bias\n• Once filled, FVG is invalidated\n• Combine with OB for strongest entries")
    else
        box.set_right(bearFVGBox, bar_index + 5)
        label.set_x(bearFVGTip, bar_index + 5)
        label.set_y(bearFVGTip, (bearFVG_top + bearFVG_bot) / 2)
if barstate.islast and (not i_showFVG or not bullFVG_active) and not na(bullFVGBox)
    box.delete(bullFVGBox)
    label.delete(bullFVGTip)
    bullFVGBox := na
    bullFVGTip := na

if barstate.islast and (not i_showFVG or not bearFVG_active) and not na(bearFVGBox)
    box.delete(bearFVGBox)
    label.delete(bearFVGTip)
    bearFVGBox := na
    bearFVGTip := na

// HTF S/R Lines
var line htfR1Line = na
var line htfR2Line = na
var line htfS1Line = na
var line htfS2Line = na

if i_showHTFsr and barstate.islast
    line.delete(htfR1Line)
    line.delete(htfR2Line)
    line.delete(htfS1Line)
    line.delete(htfS2Line)
    if not na(htfR1)
        htfR1Line := line.new(bar_index - 50, htfR1, bar_index + 10, htfR1, color=color.new(#e91e63, 30), style=line.style_solid, width=1)
    if not na(htfR2)
        htfR2Line := line.new(bar_index - 50, htfR2, bar_index + 10, htfR2, color=color.new(#e91e63, 60), style=line.style_dotted, width=1)
    if not na(htfS1)
        htfS1Line := line.new(bar_index - 50, htfS1, bar_index + 10, htfS1, color=color.new(#4caf50, 30), style=line.style_solid, width=1)
    if not na(htfS2)
        htfS2Line := line.new(bar_index - 50, htfS2, bar_index + 10, htfS2, color=color.new(#4caf50, 60), style=line.style_dotted, width=1)

// ── MAIN ENTRY SIGNAL — large arrow + detailed label ─────────────────
plotshape(i_showSignals and longSignal,  title="LONG", style=shape.labelup,
     location=location.belowbar, color=color.new(#00e676, 0),
     textcolor=color.black, text="LONG", size=size.large)
plotshape(i_showSignals and shortSignal, title="SHORT", style=shape.labeldown,
     location=location.abovebar, color=color.new(#ff1744, 0),
     textcolor=color.white, text="SHORT", size=size.large)

// Big detailed label with Entry/SL/TP/RR right next to the signal
if i_showSignals and longSignal
    longReasonTip = "🎯 SNIPER LONG SIGNAL FIRED\n\nALL conditions met:\n✓ LTF trend: " + trendLabel + "\n✓ MTF aligned (M1/M2/M3 all bullish)\n✓ Pattern: " + patternReason + "\n✓ Bullish candle close confirmed\n✓ " + (isBTCSymbol ? "(BTC itself)" : "BTC correlation OK") + "\n✓ " + str.tostring(longConfCount) + "/" + str.tostring(activeModules) + " advanced confirmations\n✓ R:R = 1:" + str.tostring(math.round(longRR, 2)) + " (min " + str.tostring(minRR) + ")\n✓ Confidence: " + str.tostring(confLong) + "% (min " + str.tostring(minConf) + "%)\n✓ Cooldown OK · Daily cap OK · No news blackout\n\nTRADE PLAN:\nEntry: " + str.tostring(close, format.mintick) + "\nSL: " + str.tostring(longSL, format.mintick) + " (structure-based)\nTP1: " + str.tostring(longTP1_plan, format.mintick) + " (40% at " + str.tostring(i_tp1R) + "R)\nTP2: " + str.tostring(longTP2_plan, format.mintick) + " (30% at " + str.tostring(i_tp2R) + "R)\nRunner: trail at " + str.tostring(i_trailATR) + "× ATR"

    label.new(bar_index, low - atr * 2.5,
         "🎯 LONG SIGNAL\nEntry: " + str.tostring(close, format.mintick) +
         "\nSL: " + str.tostring(longSL, format.mintick) +
         "\nTP1: " + str.tostring(longTP1_plan, format.mintick) +
         "\nTP2: " + str.tostring(longTP2_plan, format.mintick) +
         "\nR:R 1:" + str.tostring(math.round(longRR, 2)) +
         "\nConf: " + str.tostring(confLong) + "%",
         color=color.new(#00e676, 0), textcolor=color.black,
         style=label.style_label_up, size=sizeLabel,
         tooltip=longReasonTip)

if i_showSignals and shortSignal
    shortReasonTip = "🎯 SNIPER SHORT SIGNAL FIRED\n\nALL conditions met:\n✓ LTF trend: " + trendLabel + "\n✓ MTF aligned (M1/M2/M3 all bearish)\n✓ Pattern: " + patternReason + "\n✓ Bearish candle close confirmed\n✓ " + (isBTCSymbol ? "(BTC itself)" : "BTC correlation OK") + "\n✓ " + str.tostring(shortConfCount) + "/" + str.tostring(activeModules) + " advanced confirmations\n✓ R:R = 1:" + str.tostring(math.round(shortRR, 2)) + " (min " + str.tostring(minRR) + ")\n✓ Confidence: " + str.tostring(confShort) + "% (min " + str.tostring(minConf) + "%)\n✓ Cooldown OK · Daily cap OK · No news blackout\n\nTRADE PLAN:\nEntry: " + str.tostring(close, format.mintick) + "\nSL: " + str.tostring(shortSL, format.mintick) + " (structure-based)\nTP1: " + str.tostring(shortTP1_plan, format.mintick) + " (40% at " + str.tostring(i_tp1R) + "R)\nTP2: " + str.tostring(shortTP2_plan, format.mintick) + " (30% at " + str.tostring(i_tp2R) + "R)\nRunner: trail at " + str.tostring(i_trailATR) + "× ATR"

    label.new(bar_index, high + atr * 2.5,
         "🎯 SHORT SIGNAL\nEntry: " + str.tostring(close, format.mintick) +
         "\nSL: " + str.tostring(shortSL, format.mintick) +
         "\nTP1: " + str.tostring(shortTP1_plan, format.mintick) +
         "\nTP2: " + str.tostring(shortTP2_plan, format.mintick) +
         "\nR:R 1:" + str.tostring(math.round(shortRR, 2)) +
         "\nConf: " + str.tostring(confShort) + "%",
         color=color.new(#ff1744, 0), textcolor=color.white,
         style=label.style_label_down, size=sizeLabel,
         tooltip=shortReasonTip)

barcolor(longSignal  ? color.new(#00e676, 0) : na, title="LONG Bar")
barcolor(shortSignal ? color.new(#ff1744, 0) : na, title="SHORT Bar")
bgcolor(longSignal  ? color.new(#00e676, 80) : na, title="LONG Flash")
bgcolor(shortSignal ? color.new(#ff1744, 80) : na, title="SHORT Flash")
bgcolor(dailyDD_hit ? color.new(#ff1744, 92) : na, title="Daily DD Halt")
bgcolor(inNewsBlackout ? color.new(#9e9e9e, 92) : na, title="News Blackout")

// SL / TP visualization
plot(i_showSLTP and strategy.position_size > 0 ? longSL  : na, "SL Long",  color=color.new(#ef5350, 0), style=plot.style_linebr, linewidth=2)
plot(i_showSLTP and strategy.position_size > 0 ? longTP1_plan : na, "TP1 Long",  color=color.new(#00e676, 30), style=plot.style_linebr, linewidth=1)
plot(i_showSLTP and strategy.position_size > 0 and i_useMultiTP ? longTP2_plan : na, "TP2 Long",  color=color.new(#00e676, 0),  style=plot.style_linebr, linewidth=2)
plot(i_showSLTP and strategy.position_size < 0 ? shortSL : na, "SL Short", color=color.new(#ef5350, 0), style=plot.style_linebr, linewidth=2)
plot(i_showSLTP and strategy.position_size < 0 ? shortTP1_plan : na, "TP1 Short", color=color.new(#00e676, 30), style=plot.style_linebr, linewidth=1)
plot(i_showSLTP and strategy.position_size < 0 and i_useMultiTP ? shortTP2_plan : na, "TP2 Short", color=color.new(#00e676, 0),  style=plot.style_linebr, linewidth=2)
plot(i_showSLTP and strategy.position_size > 0 ? longTrail  : na, "Trail Long",  color=color.new(#ffa726, 30), linewidth=2, style=plot.style_linebr)
plot(i_showSLTP and strategy.position_size < 0 ? shortTrail : na, "Trail Short", color=color.new(#ffa726, 30), linewidth=2, style=plot.style_linebr)

// ╔══════════════════════════════════════════════════════════════════╗
// ║      🚨 GIANT SIGNAL BANNER — Pops up on every trade signal      ║
// ║      Stays visible for the lifetime of the trade                 ║
// ╚══════════════════════════════════════════════════════════════════╝
var table sigBanner = na
var int   sigBannerBar = na
var string sigBannerType = ""
var float  sigBannerEntry = na
var float  sigBannerSL = na
var float  sigBannerTP1 = na
var float  sigBannerTP2 = na
var float  sigBannerRR = na
var int    sigBannerConf = na

// Capture signal details when it fires
if longSignal
    sigBannerBar   := bar_index
    sigBannerType  := "LONG"
    sigBannerEntry := close
    sigBannerSL    := longSL
    sigBannerTP1   := longTP1_plan
    sigBannerTP2   := longTP2_plan
    sigBannerRR    := longRR
    sigBannerConf  := confLong

if shortSignal
    sigBannerBar   := bar_index
    sigBannerType  := "SHORT"
    sigBannerEntry := close
    sigBannerSL    := shortSL
    sigBannerTP1   := shortTP1_plan
    sigBannerTP2   := shortTP2_plan
    sigBannerRR    := shortRR
    sigBannerConf  := confShort

// Show banner for 50 bars after signal, or while position is open
showBanner = not na(sigBannerBar) and ((bar_index - sigBannerBar) <= 50 or strategy.position_size != 0)

if showBanner and barstate.islast
    table.delete(sigBanner)
    bannerBG = sigBannerType == "LONG" ? color.new(#00e676, 5) : color.new(#ff1744, 5)
    bannerTC = sigBannerType == "LONG" ? color.black : color.white
    arrow    = sigBannerType == "LONG" ? "▲" : "▼"

    sigBanner := table.new(position.middle_center, columns=1, rows=7,
         border_color=color.new(#ffffff, 0), border_width=2,
         frame_color=color.new(#ffffff, 0), frame_width=3,
         bgcolor=bannerBG)

    table.cell(sigBanner, 0, 0, arrow + " SNIPER " + sigBannerType + " " + arrow,
         text_color=bannerTC, text_size=size.huge, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 1, syminfo.ticker + " · " + timeframe.period,
         text_color=bannerTC, text_size=size.large, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 2, "Entry: " + str.tostring(sigBannerEntry, format.mintick),
         text_color=bannerTC, text_size=size.large, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 3, "SL: " + str.tostring(sigBannerSL, format.mintick),
         text_color=bannerTC, text_size=size.large, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 4, "TP1: " + str.tostring(sigBannerTP1, format.mintick) + "  |  TP2: " + str.tostring(sigBannerTP2, format.mintick),
         text_color=bannerTC, text_size=size.large, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 5, "R:R 1:" + str.tostring(math.round(sigBannerRR, 2)) + "   ·   Confidence: " + str.tostring(sigBannerConf) + "%",
         text_color=bannerTC, text_size=size.large, bgcolor=bannerBG, text_halign=text.align_center)
    table.cell(sigBanner, 0, 6, strategy.position_size != 0 ? "● POSITION OPEN ●" : "(banner expires in " + str.tostring(50 - (bar_index - sigBannerBar)) + " bars)",
         text_color=bannerTC, text_size=size.normal, bgcolor=bannerBG, text_halign=text.align_center)

if not showBanner and barstate.islast and not na(sigBanner)
    table.delete(sigBanner)
    sigBanner := na

// ╔══════════════════════════════════════════════════════════════════╗
// ║                        DASHBOARD                                 ║
// ╚══════════════════════════════════════════════════════════════════╝
tablePos = i_dashPos == "Top Right" ? position.top_right : i_dashPos == "Top Left" ? position.top_left : i_dashPos == "Bottom Right" ? position.bottom_right : i_dashPos == "Bottom Left" ? position.bottom_left : position.middle_right

var table dash = na

// Create table ONCE (persists across all bars - never disappears)
if i_showDash and barstate.isfirst
    dash := table.new(tablePos, columns=2, rows=27,
         border_color=color.new(#7c4dff, 0), border_width=1,
         frame_color=color.new(#7c4dff, 50), frame_width=1, bgcolor=color.new(#0d1117, 0))

// Populate cells on last bar OR last confirmed bar (whichever fires)
if i_showDash and (barstate.islast or barstate.islastconfirmedhistory)
    col_bg   = color.new(#0d1117, 0)        // fully opaque background
    col_hdr  = color.new(#4a148c, 0)         // brighter purple header
    col_row  = color.new(#1a1a2e, 0)         // brighter row background
    col_bull = color.new(#00e676, 0)
    col_bear = color.new(#ff1744, 0)
    col_neut = color.new(#b0bec5, 0)
    col_warn = color.new(#ff9800, 0)

    table.cell(dash, 0, 0, "⚡ CRYPTO SNIPER PRO", text_color=color.white, text_size=sizeHeader, bgcolor=col_hdr, text_halign=text.align_center)
    table.cell(dash, 1, 0, "v5.0", text_color=color.white, text_size=sizeHeader, bgcolor=col_hdr, text_halign=text.align_center)

    // Last signal info (persists across bars)
    lastSigTxt = na(sigBannerBar) ? "No signal yet" : sigBannerType + " · " + str.tostring(bar_index - sigBannerBar) + " bars ago"
    lastSigC   = na(sigBannerBar) ? col_neut : sigBannerType == "LONG" ? col_bull : col_bear
    table.cell(dash, 0, 1, "📍 Last Signal", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Most recent SNIPER signal that fired on this chart. Shows direction (LONG/SHORT) and how many bars ago. The full trade details are preserved in the chart label at that bar.")
    table.cell(dash, 1, 1, lastSigTxt, text_color=lastSigC, text_size=sizeText, bgcolor=col_row)

    presetTxt = i_preset
    presetC   = i_preset == "Strict (sniper)" ? col_bull : i_preset == "Aggressive" ? col_warn : col_neut
    table.cell(dash, 0, 2, "🎚 Preset", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Quick configuration switcher. STRICT = 1-3 trades/week max accuracy. BALANCED = 3-8/week good mix. AGGRESSIVE = 10-20/week more signals. CUSTOM = use your own settings.")
    table.cell(dash, 1, 2, presetTxt, text_color=presetC, text_size=sizeText, bgcolor=col_row)

    // Wyckoff phase row
    phaseTxt = currentPhase + (manipulationBull ? " ↑" : manipulationBear ? " ↓" : "")
    table.cell(dash, 0, 3, "🔬 Wyckoff", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Current Wyckoff market phase: ACCUMULATION (sideways after downtrend), MANIPULATION (stop hunt before move), MARKUP (active bull), DISTRIBUTION (sideways after uptrend), MARKDOWN (active bear).")
    table.cell(dash, 1, 3, phaseTxt, text_color=phaseColor, text_size=sizeText, bgcolor=col_row)

    table.cell(dash, 0, 4, "🔭 Chart TF", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Your current chart timeframe + the 3 higher TFs being analyzed for trend bias. MTF auto-scales based on your chart TF (e.g. 15m chart → 1H+4H+D bias).")
    table.cell(dash, 1, 4, timeframe.period + "  (MTF: " + mtf1 + "/" + mtf2 + "/" + mtf3 + ")", text_color=col_neut, text_size=sizeText, bgcolor=col_row)

    mtfTxt = "M1:" + (mtf1Bias==1?"▲":mtf1Bias==-1?"▼":"=") + " M2:" + (mtf2Bias==1?"▲":mtf2Bias==-1?"▼":"=") + " M3:" + (mtf3Bias==1?"▲":mtf3Bias==-1?"▼":"=")
    mtfC   = mtfFullBull ? col_bull : mtfFullBear ? col_bear : col_warn
    table.cell(dash, 0, 5, "🔭 MTF Bias", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Multi-timeframe trend alignment. ▲ = bullish, ▼ = bearish, = neutral. All 3 TFs MUST agree for a signal to fire. M1=closest higher TF, M3=highest.")
    table.cell(dash, 1, 5, mtfTxt, text_color=mtfC, text_size=sizeText, bgcolor=col_row)

    ltfC   = ltfTrendBull ? col_bull : ltfTrendBear ? col_bear : col_neut
    table.cell(dash, 0, 6, "📈 LTF Trend", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Lower-timeframe (your chart) trend strength. STRONG BULL = EMA20>50>200 + rising slope. STRONG BEAR = inverse. MIXED = no clear trend.")
    table.cell(dash, 1, 6, trendLabel, text_color=ltfC, text_size=sizeText, bgcolor=col_row)

    structTxt = extBullStruct ? "BULL HH/HL" : extBearStruct ? "BEAR LH/LL" : "NEUTRAL"
    structC   = extBullStruct ? col_bull : extBearStruct ? col_bear : col_neut
    table.cell(dash, 0, 7, "🏗 Structure", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="External market structure based on major pivots only (no internal noise). BULL HH/HL = higher highs + higher lows. BEAR LH/LL = lower highs + lower lows.")
    table.cell(dash, 1, 7, structTxt, text_color=structC, text_size=sizeText, bgcolor=col_row)

    btcTxt = isBTCSymbol ? "(THIS IS BTC)" : btcBull ? "BTC: BULL ✓" : btcBear ? "BTC: BEAR ✓" : "BTC: MIXED"
    btcC   = isBTCSymbol ? col_neut : btcBull ? col_bull : btcBear ? col_bear : col_warn
    table.cell(dash, 0, 8, "₿ BTC Filter", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Bitcoin correlation gate for altcoins. Alts must align with BTC trend before signals fire. Auto-disables when chart symbol contains BTC.")
    table.cell(dash, 1, 8, btcTxt, text_color=btcC, text_size=sizeText, bgcolor=col_row)

    // Crypto Sentiment row
    sentTxt = str.tostring(sentimentScore) + " · " + sentimentLabel
    sentC   = extremeGreed ? col_bear : greed ? col_warn : extremeFear ? col_bull : fear ? col_warn : col_neut
    table.cell(dash, 0, 9, "🌡 Sentiment", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="🌡 CRYPTO SENTIMENT SCORE (0-100)\n\nWHAT: Composite sentiment from 4 free sources:\n• TOTAL Market Cap trend & RSI (fear/greed proxy)\n• BTC Dominance (alt season indicator)\n• USDT.D Stablecoin Dominance (risk-on/off)\n• TOTAL3 (alt-specific strength)\n\nINTERPRETATION:\n• 0-30 EXTREME FEAR: contrarian BULLISH (buy when fearful)\n• 30-40 FEAR: bullish bias\n• 40-60 NEUTRAL: follow trend\n• 60-70 GREED: bearish bias\n• 70-100 EXTREME GREED: contrarian BEARISH (sell when greedy)\n\nIMPACT:\n• Extreme greed BLOCKS longs (sentOK_long=false)\n• Extreme fear BLOCKS shorts (sentOK_short=false)\n• Aligned sentiment ADDS +10 to confidence score\n\nThis is the WARREN BUFFETT rule: \"be fearful when others are greedy and greedy when others are fearful\".")
    table.cell(dash, 1, 9, sentTxt, text_color=sentC, text_size=sizeText, bgcolor=col_row)

    htfsrTxt = nearHTFsupport ? "Near HTF Support ✓" : nearHTFresist ? "Near HTF Resist ✓" : "None"
    htfsrC   = nearHTFsupport ? col_bull : nearHTFresist ? col_bear : col_neut
    table.cell(dash, 0, 10, "🏛 HTF S/R", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Higher-timeframe support/resistance levels (auto-detected from daily pivots). Signals near these levels get a confidence boost — they are key institutional zones.")
    table.cell(dash, 1, 10, htfsrTxt, text_color=htfsrC, text_size=sizeText, bgcolor=col_row)

    rsiTxt = str.tostring(rsi, "#.#") + (rsiOversold ? " OS" : rsiOverbought ? " OB" : bullDiv ? " +Div" : bearDiv ? " -Div" : "")
    rsiC   = bullDiv or rsiOversold ? col_bull : bearDiv or rsiOverbought ? col_bear : col_neut
    table.cell(dash, 0, 11, "📊 RSI", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="RSI value + status. OS=oversold (<30 bullish setup). OB=overbought (>70 bearish setup). +Div=bullish divergence. -Div=bearish divergence.")
    table.cell(dash, 1, 11, rsiTxt, text_color=rsiC, text_size=sizeText, bgcolor=col_row)

    macdTxt = macdBullShift ? "BULL SHIFT" : macdBearShift ? "BEAR SHIFT" : macdBullState ? "Bull" : macdBearState ? "Bear" : "Mixed"
    macdC   = macdBullShift or macdBullState ? col_bull : macdBearShift or macdBearState ? col_bear : col_neut
    table.cell(dash, 0, 12, "📊 MACD", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="MACD momentum state. BULL SHIFT=fresh crossover up. BEAR SHIFT=fresh crossover down. Bull/Bear=trend continuation. Histogram acceleration also detected.")
    table.cell(dash, 1, 12, macdTxt, text_color=macdC, text_size=sizeText, bgcolor=col_row)

    volTxt = str.tostring(volume / volMA, "#.#") + "× avg" + (volSpike ? " ✓" : "")
    volC   = volSpike ? col_bull : col_neut
    table.cell(dash, 0, 13, "📊 Volume", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Current volume vs 20-bar average. ✓ marker = spike above 1.5× average. Volume spike confirms smart money activity behind moves.")
    table.cell(dash, 1, 13, volTxt, text_color=volC, text_size=sizeText, bgcolor=col_row)

    cvdTxt = cvdBullDiv ? "BULL DIV ✓" : cvdBearDiv ? "BEAR DIV ✓" : cvdDelta > 0 ? "Buy pressure" : cvdDelta < 0 ? "Sell pressure" : "Neutral"
    cvdC   = cvdBullDiv or cvdDelta > 0 ? col_bull : cvdBearDiv or cvdDelta < 0 ? col_bear : col_neut
    table.cell(dash, 0, 14, "📊 CVD", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Cumulative Volume Delta proxy. Estimates aggressive buy vs sell pressure. BULL DIV = price low + CVD high (bullish reversal). BEAR DIV = opposite.")
    table.cell(dash, 1, 14, cvdTxt, text_color=cvdC, text_size=sizeText, bgcolor=col_row)

    obfvgTxt = inBullOB ? "IN BULL OB" : inBearOB ? "IN BEAR OB" : inBullFVG ? "IN BULL FVG" : inBearFVG ? "IN BEAR FVG" : "None"
    obfvgC   = inBullOB or inBullFVG ? col_bull : inBearOB or inBearFVG ? col_bear : col_neut
    table.cell(dash, 0, 15, "🟦 Zones", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Current price interaction with smart money zones. IN BULL OB = price tapping bullish order block. IN BULL FVG = price filling bullish fair value gap.")
    table.cell(dash, 1, 15, obfvgTxt, text_color=obfvgC, text_size=sizeText, bgcolor=col_row)

    volRegTxt = "ATR " + str.tostring(atrPct, "#.##") + "% · ADX " + str.tostring(adx, "#")
    volRegC   = volRegimeOK ? col_bull : col_warn
    table.cell(dash, 0, 16, "💨 Vol Regime", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Volatility health check. ATR% measures market liveness (>0.3% needed). ADX measures trend strength (>20 needed). Both must pass to allow trades.")
    table.cell(dash, 1, 16, volRegTxt, text_color=volRegC, text_size=sizeText, bgcolor=col_row)

    sessTxt = not inSession ? "OFF-SESSION ✗" : inNY and inLondon ? "LDN+NY ★" : inNY ? "NY" : inLondon ? "London" : "Open"
    sessC   = not inSession ? col_warn : col_bull
    table.cell(dash, 0, 17, "🕐 Session", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Current trading session. LDN+NY ★ = London/NY overlap (best volatility). NY/London = single session. OFF-SESSION ✗ = trading paused (chop filter).")
    table.cell(dash, 1, 17, sessTxt, text_color=sessC, text_size=sizeText, bgcolor=col_row)

    // Combined funding + news row
    fundPart = i_useFunding ? "Fund " + str.tostring(i_fundingPct, "#.###") + "%" + (fundingExtremeLong ? "⚠L" : fundingExtremeShort ? "⚠S" : "✓") : "Fund OFF"
    newsPart = inNewsBlackout ? " | 📰 " + newsEventName + " ⛔" : ""
    fundTxt = fundPart + newsPart
    fundC   = inNewsBlackout ? col_bear : not i_useFunding ? col_neut : fundingExtremeLong or fundingExtremeShort ? col_warn : col_bull
    table.cell(dash, 0, 18, "💰 Funding/News", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Funding rate (manual input from exchange) + auto news blackout. Extreme funding = contrarian bias. ⛔ = trading paused for FOMC/CPI/NFP/news.")
    table.cell(dash, 1, 18, fundTxt, text_color=fundC, text_size=sizeText, bgcolor=col_row)

    longConfTxt = str.tostring(longConfCount) + "/" + str.tostring(activeModules) + " (need " + str.tostring(minConfirm) + "+)"
    table.cell(dash, 0, 19, "🟢 LONG Conf", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="How many of your enabled confluence modules currently agree on LONG. Need at least Min Confirmations (set by preset) to fire signal.")
    table.cell(dash, 1, 19, longConfTxt, text_color=longConfCount >= minConfirm ? col_bull : col_neut, text_size=sizeText, bgcolor=col_row)

    shortConfTxt = str.tostring(shortConfCount) + "/" + str.tostring(activeModules) + " (need " + str.tostring(minConfirm) + "+)"
    table.cell(dash, 0, 20, "🔴 SHORT Conf", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="How many of your enabled confluence modules currently agree on SHORT. Need at least Min Confirmations (set by preset) to fire signal.")
    table.cell(dash, 1, 20, shortConfTxt, text_color=shortConfCount >= minConfirm ? col_bear : col_neut, text_size=sizeText, bgcolor=col_row)

    bestConf = longSignal ? confLong : shortSignal ? confShort : math.max(confLong, confShort)
    confC    = bestConf >= minConf ? col_bull : bestConf >= minConf - 15 ? col_warn : col_neut
    table.cell(dash, 0, 21, "🎯 Confidence", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Weighted confidence score 0-100%. Combines MTF (30%), pattern (15%), candle (10%), confluences (35%), HTF S/R (10%). Must exceed preset minimum.")
    table.cell(dash, 1, 21, str.tostring(bestConf) + "% (need " + str.tostring(minConf) + "%)", text_color=confC, text_size=sizeText, bgcolor=col_row)

    streakTxt = winStreakC > 0 ? "WIN " + str.tostring(winStreakC) + " (size " + str.tostring(math.round(streakMult * 100)) + "%)" : lossStreakC > 0 ? "LOSS " + str.tostring(lossStreakC) + " (size " + str.tostring(math.round(streakMult * 100)) + "%)" : "Neutral"
    streakC   = winStreakC >= i_winStreak ? col_bull : lossStreakC >= i_lossStreak ? col_warn : col_neut
    table.cell(dash, 0, 22, "🔄 Streak", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Win/loss streak position sizing. After 2 losses: position size REDUCED by 50% (recovery mode). After 3 wins: position size INCREASED 50% (heat).")
    table.cell(dash, 1, 22, streakTxt, text_color=streakC, text_size=sizeText, bgcolor=col_row)

    ddTxt = str.tostring(dailyDD_pct, "#.##") + "% (" + str.tostring(tradesToday) + "/" + str.tostring(maxPerDay) + " trades)"
    ddC   = dailyDD_hit ? col_bear : dailyDD_pct < 0 ? col_warn : col_bull
    table.cell(dash, 0, 23, "🚨 Day P&L", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Today's P&L % + trades count. Circuit breaker stops all trading if daily loss exceeds -3% (configurable). Resets at midnight UTC.")
    table.cell(dash, 1, 23, ddTxt, text_color=ddC, text_size=sizeText, bgcolor=col_row)

    pf      = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : 0.0
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0.0
    maxDD   = strategy.max_drawdown / strategy.initial_capital * 100
    perfTxt = "WR " + str.tostring(winRate,"#") + "% · PF " + str.tostring(pf,"#.##") + " · Sh " + str.tostring(sharpeApprox,"#.##") + " · DD " + str.tostring(maxDD,"#") + "%"
    perfC   = winRate >= 50 and pf >= 1.5 ? col_bull : winRate >= 40 ? col_warn : col_bear
    table.cell(dash, 0, 24, "📊 Backtest", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="Strategy performance: Win Rate, Profit Factor (gross profit/gross loss), Sharpe ratio approximation, Max Drawdown. WR>50% + PF>1.5 is healthy.")
    table.cell(dash, 1, 24, perfTxt, text_color=perfC, text_size=sizeText, bgcolor=col_row)
    // Diagnostic - what's blocking the signal? (only when no signal fires)
    // Check which condition is missing for both LONG and SHORT
    longBlocker = strategy.position_size != 0 ? "Position open" : not i_allowLong ? "Long disabled" : not trendPassLong ? "Trend not bull" : not mtfPassLong ? "MTF not aligned" : not patternBull ? "No pattern" : not candlePassLong ? "No bull candle" : not btcOKLong ? "BTC not bull" : not fundingOK_long ? "Funding ⚠" : not oiOKLong ? "OI weak" : not sentOK_long ? "Sentiment ⚠" : inNewsBlackout ? "News block" : not weekendOK ? "Weekend" : longConfCount < minConfirm ? "Confs " + str.tostring(longConfCount) + "/" + str.tostring(minConfirm) : confLong < minConf ? "Conf " + str.tostring(confLong) + "%<" + str.tostring(minConf) + "%" : not rrOK_long ? "R:R<" + str.tostring(minRR) : not cooldownOK ? "Cooldown" : not dailyCapOK ? "Day cap" : not inDateRange ? "Date range" : dailyDD_hit ? "DD halt" : not htfsrConfLong ? "HTF S/R" : "READY"

    shortBlocker = strategy.position_size != 0 ? "Position open" : not i_allowShort ? "Short disabled" : not trendPassShort ? "Trend not bear" : not mtfPassShort ? "MTF not aligned" : not patternBear ? "No pattern" : not candlePassShort ? "No bear candle" : not btcOKShort ? "BTC not bear" : not fundingOK_short ? "Funding ⚠" : not oiOKShort ? "OI weak" : not sentOK_short ? "Sentiment ⚠" : inNewsBlackout ? "News block" : not weekendOK ? "Weekend" : shortConfCount < minConfirm ? "Confs " + str.tostring(shortConfCount) + "/" + str.tostring(minConfirm) : confShort < minConf ? "Conf " + str.tostring(confShort) + "%<" + str.tostring(minConf) + "%" : not rrOK_short ? "R:R<" + str.tostring(minRR) : not cooldownOK ? "Cooldown" : not dailyCapOK ? "Day cap" : not inDateRange ? "Date range" : dailyDD_hit ? "DD halt" : not htfsrConfShort ? "HTF S/R" : "READY"

    // Show the side that's CLOSER to firing (fewer blockers)
    blockerTxt = "L: " + longBlocker + "  |  S: " + shortBlocker

    table.cell(dash, 0, 25, "🔍 Blocker", text_color=color.new(#b0bec5,0), text_size=sizeText, bgcolor=col_row, tooltip="🔍 SIGNAL BLOCKER DIAGNOSTIC\n\nShows WHY no signal is currently firing.\n\nFormat: L: [long blocker] | S: [short blocker]\n\nIf both say READY but no signal: the candle hasn't closed yet (signals only fire on confirmed bar close).\n\nIf you see persistent blockers like 'MTF not aligned' — that means your chosen confluence filters are not in agreement on this pair/TF.\n\nTo get more signals: switch preset to Aggressive, OR disable blocking modules in Master Switches.")
    table.cell(dash, 1, 25, blockerTxt, text_color=col_warn, text_size=sizeText, bgcolor=col_row)

    sigBG  = dailyDD_hit ? color.new(#9e9e9e, 30) : longSignal ? color.new(#00e676, 30) : shortSignal ? color.new(#ff1744, 30) : color.new(#37474f, 60)
    sigTxt = dailyDD_hit ? "⛔ DAILY DD HALT" : longSignal ? "▲ SNIPER LONG" : shortSignal ? "▼ SNIPER SHORT" : "— WAITING —"
    sigTC  = longSignal ? color.black : color.white
    table.cell(dash, 0, 26, "SIGNAL", text_color=color.white, text_size=sizeText, bgcolor=sigBG, tooltip="Final signal status. ▲ SNIPER LONG / ▼ SNIPER SHORT = trade fired. ⛔ DAILY DD HALT = trading paused. WAITING = scanning for setup.")
    table.cell(dash, 1, 26, sigTxt, text_color=sigTC, text_size=sizeText, bgcolor=sigBG, text_halign=text.align_center)

// ╔══════════════════════════════════════════════════════════════════╗
// ║                       ALERTS (DUAL)                              ║
// ╚══════════════════════════════════════════════════════════════════╝


// Shared alert payload fields
alertStrategyVersion = "v5.0"
alertSymbol          = syminfo.ticker
alertTimeframe       = timeframe.period
alertTimestamp       = str.tostring(time)

alertLongSide        = "BUY"
alertShortSide       = "SELL"
alertLongEntry       = close
alertShortEntry      = close
alertLongStopLoss    = longSL
alertShortStopLoss   = shortSL
alertLongTakeProfit  = longTP1_plan
alertShortTakeProfit = shortTP1_plan
alertLongTakeProfit2 = longTP2_plan
alertShortTakeProfit2 = shortTP2_plan
alertLongConfidence  = confLong
alertShortConfidence = confShort

f_alertPlain(_symbol, _timeframe, _side, _entry, _stopLoss, _takeProfit, _takeProfit2, _confidence, _timestamp, _version) =>
    "Crypto Sniper Pro | Symbol: " + _symbol + " | Timeframe: " + _timeframe + " | Side: " + _side + " | Entry: " + str.tostring(_entry, format.mintick) + " | Stop Loss: " + str.tostring(_stopLoss, format.mintick) + " | Take Profit: " + str.tostring(_takeProfit, format.mintick) + " | Take Profit 2: " + str.tostring(_takeProfit2, format.mintick) + " | Confidence: " + str.tostring(_confidence) + "% | Timestamp: " + _timestamp + " | Strategy Version: " + _version

f_alertJson(_symbol, _timeframe, _side, _entry, _stopLoss, _takeProfit, _takeProfit2, _confidence, _timestamp, _version) =>
    '{"strategy_version":"' + _version + '","symbol":"' + _symbol + '","timeframe":"' + _timeframe + '","side":"' + _side + '","entry":' + str.tostring(_entry, format.mintick) + ',"stop_loss":' + str.tostring(_stopLoss, format.mintick) + ',"take_profit":' + str.tostring(_takeProfit, format.mintick) + ',"take_profit_2":' + str.tostring(_takeProfit2, format.mintick) + ',"confidence":' + str.tostring(_confidence) + ',"timestamp":' + _timestamp + '}'

plainLong  = f_alertPlain(alertSymbol, alertTimeframe, alertLongSide, alertLongEntry, alertLongStopLoss, alertLongTakeProfit, alertLongTakeProfit2, alertLongConfidence, alertTimestamp, alertStrategyVersion)
plainShort = f_alertPlain(alertSymbol, alertTimeframe, alertShortSide, alertShortEntry, alertShortStopLoss, alertShortTakeProfit, alertShortTakeProfit2, alertShortConfidence, alertTimestamp, alertStrategyVersion)

jsonLong  = f_alertJson(alertSymbol, alertTimeframe, alertLongSide, alertLongEntry, alertLongStopLoss, alertLongTakeProfit, alertLongTakeProfit2, alertLongConfidence, alertTimestamp, alertStrategyVersion)
jsonShort = f_alertJson(alertSymbol, alertTimeframe, alertShortSide, alertShortEntry, alertShortStopLoss, alertShortTakeProfit, alertShortTakeProfit2, alertShortConfidence, alertTimestamp, alertStrategyVersion)

longMsg  = i_alertFormat == "JSON (webhook)" ? jsonLong  : plainLong
shortMsg = i_alertFormat == "JSON (webhook)" ? jsonShort : plainShort

if longSignal
    alert(longMsg, alert.freq_once_per_bar_close)
if shortSignal
    alert(shortMsg, alert.freq_once_per_bar_close)

alertcondition(longSignal,  title="🟢 Crypto Sniper LONG",  message="LONG signal — check chart & dashboard")
alertcondition(shortSignal, title="🔴 Crypto Sniper SHORT", message="SHORT signal — check chart & dashboard")
alertcondition(longSignal or shortSignal, title="🎯 Crypto Sniper ANY", message="Sniper signal fired")
dailyDDAlert = dailyDD_hit and not dailyDD_hit[1]
alertcondition(dailyDDAlert, title="⛔ Daily DD Hit", message="Daily loss limit hit — trading paused")
